+          </Typography>
+        </DialogContent>
+        <DialogFooter>
+          <Button form="configure-form" type="reset" theme="warning">
+            Reset
+          </Button>
+          <Button
+            form="configure-form"
+            type="submit"
+            theme="primary"
+            disabled={error}
+          >
+            Confirm
+          </Button>
+        </DialogFooter>
+      </Dialog>
+    </div>
+  );
+}
