+import { FloatingActionButtonPosition } from "@react-md/button";
+import {
+  useFixedPositioning,
+  useScrollLock,
+  UseStateSetter,
+  useUserInteractionMode,
+} from "@react-md/core";
+import { ReactElement, RefObject, useRef, useState } from "react";
+import { useMenuBarContext } from "./MenuBarProvider";
+import { MenuButton } from "./MenuButton";
+import { MenuItemButton } from "./MenuItemButton";
+import { MenuRenderer } from "./MenuRenderer";
+import {
+  MenuVisibilityProvider,
+  useMenuVisibilityProvider,
+} from "./MenuVisibilityProvider";
+import {
+  DropdownMenuButtonProps,
+  DropdownMenuConfigurationProps,
+  DropdownMenuItemProps,
+  DropdownMenuProps,
+  DropdownMenuVisibilityProps,
+} from "./types";
+import { getDefaultAnchor } from "./utils";
+
+export function DropdownMenu(props: DropdownMenuVisibilityProps): ReactElement {
+  const {
+    menuProps,
+    menuStyle,
+    menuClassName,
+    sheetProps,
+    sheetMenuProps,
+    sheetStyle,
+    sheetClassName,
+    sheetHeader: propSheetHeader,
+    sheetFooter: propSheetFooter,
+    renderAsSheet: propRenderAsSheet,
+    sheetPosition: propSheetPosition,
+    sheetVerticalSize: propSheetVerticalSize,
+    listStyle,
+    listClassName,
+    listProps,
+    appear,
+    enter,
+    exit,
+    timeout: propTimeout,
+    classNames,
+    anchor: propAnchor,
+    getFixedPositionOptions,
+    temporary,
+    onEnter,
+    onEntering,
+    onEntered,
+    onExit,
+    onExiting,
+    onExited,
+    children,
+    horizontal: propHorizontal,
+    preventScroll = false,
+    closeOnResize,
+    closeOnScroll,
+    iconRotatorProps: propIconRotatorProps,
+    disableFocusOnMount: propDisableFocusOnMount,
+    disableFocusOnUnmount: propDisableFocusOnUnmount,
+    visible: propVisible,
+    setVisible: propSetVisible,
+    defaultVisible,
+    ...remaining
+  } = props;
+
+  // const {
+  //   horizontal,
+  //   sheetHeader,
+  //   sheetFooter,
+  //   renderAsSheet,
+  //   sheetPosition,
+  //   sheetVerticalSize,
+  // } = useMenuConfiguration({
+  //   horizontal: propHorizontal,
+  //   sheetFooter: propSheetFooter,
+  //   sheetHeader: propSheetHeader,
+  //   renderAsSheet: propRenderAsSheet,
+  //   sheetPosition: propSheetPosition,
+  //   sheetVerticalSize: propSheetVerticalSize,
+  // });
+
+  const visibilityContext = useMenuVisibilityProvider({
+    visible: propVisible as boolean,
+    setVisible: propSetVisible as UseStateSetter<boolean>,
+    defaultVisible: defaultVisible as undefined,
+    horizontal: propHorizontal,
+  });
+  const { visible, setVisible, horizontal, toggleId } = visibilityContext;
+
+  const toggleRef = useRef<HTMLButtonElement | HTMLLIElement>(null);
+  const mode = useUserInteractionMode();
+  const mouse = mode === "mouse";
+  const keyboard = mode === "keyboard";
+  const { root, menubar, menuitem, activeIdRef, animatedOnceRef } =
+    useMenuBarContext();
+
+  const cancelUnmountFocus = useRef(false);
+  const disableTransition =
+    animatedOnceRef.current &&
+    menubar &&
+    !!activeIdRef.current &&
+    (mouse || keyboard);
+  const timeout = propTimeout ?? (disableTransition ? 0 : undefined);
+
+  let iconRotatorProps = propIconRotatorProps;
+  if (disableTransition) {
+    iconRotatorProps = {
+      disableTransition: true,
+      ...propIconRotatorProps,
+    };
+  }
+
+  let floating: FloatingActionButtonPosition = null;
+  if (!menuitem) {
+    ({ floating = null } = remaining as DropdownMenuButtonProps);
+  }
+
+  const anchor = getDefaultAnchor({
+    anchor: propAnchor,
+    menubar,
+    menuitem: menuitem && !root,
+    floating,
+    horizontal,
+  });
+
+  let toggle: ReactElement;
+  if (menuitem) {
+    // see `DropdownMenuProps` about this typecast
+    const { buttonChildren, ...itemProps } = remaining as DropdownMenuItemProps;
+    const ref = toggleRef as RefObject<HTMLLIElement>;
+    toggle = (
+      <MenuItemButton
+        id={toggleId}
+        {...itemProps}
+        ref={ref}
+        iconRotatorProps={iconRotatorProps}
+      >
+        {buttonChildren}
+      </MenuItemButton>
+    );
+  } else {
+    // see `DropdownMenuProps` about this typecast
+    const { buttonChildren, ...buttonProps } =
+      remaining as DropdownMenuButtonProps;
+    const ref = toggleRef as RefObject<HTMLButtonElement>;
+    toggle = (
+      <MenuButton
+        id={toggleId}
+        {...buttonProps}
+        ref={ref}
+        iconRotatorProps={iconRotatorProps}
+      >
+        {buttonChildren}
+      </MenuButton>
+    );
+  }
+
+  useScrollLock(visible && preventScroll);
+  const { style, transitionOptions } = useFixedPositioning<
+    HTMLButtonElement | HTMLLIElement,
+    HTMLDivElement
+  >({
+    fixedTo: toggleRef,
+    anchor,
+    onEnter,
+    onEntering,
+    onEntered,
+    onExited,
+    transformOrigin: true,
+    getFixedPositionOptions,
+    onScroll(_event, data) {
+      if (!data.visible || closeOnScroll) {
+        cancelUnmountFocus.current = true;
+        setVisible(false);
+      }
+    },
+    onResize() {
+      if (closeOnResize) {
+        cancelUnmountFocus.current = true;
+        setVisible(false);
+      }
+    },
+  });
+
+  return (
+    <MenuVisibilityProvider value={visibilityContext}>
+      {toggle}
+      <MenuRenderer
+        {...transitionOptions}
+        menuProps={{
+          ...menuProps,
+          // isFocusTypeDisabled: (type) => {
+          //   const disableFocusOnMount =
+          //     propDisableFocusOnMount ?? (mouse && timeout === 0);
+          //   const disableFocusOnUnmount =
+          //     propDisableFocusOnUnmount ??
+          //     ((mouse && timeout === 0) || cancelUnmountFocus.current);
+
+          //   return (
+          //     menuProps?.isFocusTypeDisabled?.(type) ||
+          //     (type === "mount" && disableFocusOnMount) ||
+          //     (type === "unmount" && disableFocusOnUnmount)
+          //   );
+          // },
+        }}
+        menuStyle={{ ...style, ...menuStyle }}
+        menuClassName={menuClassName}
+        sheetProps={sheetProps}
+        sheetStyle={sheetStyle}
+        sheetClassName={sheetClassName}
+        sheetMenuProps={sheetMenuProps}
+        // sheetHeader={sheetHeader}
+        // sheetFooter={sheetFooter}
+        // sheetPosition={sheetPosition}
+        // sheetVerticalSize={sheetVerticalSize}
+        // renderAsSheet={renderAsSheet}
+        listStyle={listStyle}
+        listClassName={listClassName}
+        listProps={listProps}
+        horizontal={horizontal}
+        temporary={temporary}
+        appear={appear}
+        enter={enter}
+        exit={exit}
+        onExit={onExit}
+        onExiting={onExiting}
+        timeout={timeout}
+        classNames={classNames}
+      >
+        {children}
+      </MenuRenderer>
+    </MenuVisibilityProvider>
+  );
+}
