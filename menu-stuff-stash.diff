+//           //   // className: "rmd-select-value",
+//           // })}
+//           className="rmd-hidden-input"
+//           readOnly
+//           value={value}
+//         />
+//         {label && (
+//           <Label
+//             {...labelProps}
+//             htmlFor={id}
+//             style={labelProps?.style ?? labelStyle}
+//             className={labelProps?.className ?? labelClassName}
+//             floating
+//             dense={dense}
+//             error={error}
+//             active={active || !!value}
+//             disabled={disabled}
+//             inactive={!!value}
+//           >
+//             {label}
+//           </Label>
+//         )}
+//       </TextFieldContainer>
+//       <Menu {...menuProps}>{children}</Menu>
+//     </FormMessageContainer>
+//   );
+// });
+
+export type SelectValue = number | string;
+
+export interface SelectOptionObject {
+  label: ReactNode;
+  value: SelectValue;
+  disabled?: boolean;
+}
+
+export interface SelectProps<Value extends SelectValue | SelectOptionObject>
+  extends Omit<TextFieldProps, "type" | "value" | "onChange"> {
+  value: Value;
+  onChange(nextValue: Value): void;
+  inputRef?: Ref<HTMLInputElement>;
+}
+
+export function Select<Value extends SelectValue | SelectOptionObject>(
+  props: SelectProps<Value>
+): ReactElement {
+  const {
+    id: propId,
+    children,
+    inputRef,
+    value,
+    onChange,
+    ...remaining
+  } = props;
+  const id = useEnsuredId(propId, "select");
+  const { visible, menuProps, toggleProps } = useDropdownMenu({
+    role: "listbox",
+    toggleRef: inputRef,
+    width: "equal",
+    transformOrigin: true,
+    anchor: BELOW_CENTER_ANCHOR,
+    onToggleKeyDown(event) {
+      if (event.key === " ") {
+        event.preventDefault();
+        event.stopPropagation();
+        event.currentTarget.click();
+      }
+    },
+  });
+
+  const inputValue =
+    typeof value === "number" || typeof value === "string"
+      ? value
+      : value.value;
+
+  return (
+    <>
+      <TextField
+        {...remaining}
+        {...toggleProps}
+        active={visible}
+        aria-haspopup="listbox"
+        id={id}
+        role="button"
+        tabIndex={0}
+        value={inputValue}
+        readOnly
+        onFocus={(event) => {
+          const input = event.currentTarget;
+          input.setSelectionRange(null, null);
+        }}
+        onChange={(event) => {
+          console.log("event:", event);
+        }}
+      />
+      <Menu {...menuProps}>{children}</Menu>
+    </>
+  );
+}
