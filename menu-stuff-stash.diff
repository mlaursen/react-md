+//   });
+
+//   return (
+//     <FormMessageContainer
+//       {...messageContainerProps}
+//       messageProps={messageProps}
+//     >
+//       <TextFieldContainer
+//         {...remaining}
+//         {...toggleProps}
+//         aria-haspopup="listbox"
+//         role="button"
+//         tabIndex={0}
+//         style={style}
+//         className={cnb("rmd-select", className)}
+//         theme={theme}
+//         label={!!label}
+//         error={error}
+//         dense={dense}
+//         inline={inline}
+//         active={active || visible}
+//         stretch={stretch}
+//         readOnly={readOnly}
+//         disabled={disabled}
+//         leftAddon={leftAddon}
+//         rightAddon={rightAddon}
+//         underlineDirection={underlineDirection}
+//         disableLeftAddonStyles={disableLeftAddonStyles}
+//         disableRightAddonStyles={disableRightAddonStyles}
+//       >
+//         <div
+//           className={textField({
+//             className: "rmd-select-value",
+//           })}
+//         >
+//           {value}
+//         </div>
+//         <input
+//           id={id}
+//           type="hidden"
+//           aria-hidden
+//           // className={textField({
+//           //   // className: "rmd-select-value",
+//           // })}
+//           className="rmd-hidden-input"
+//           readOnly
+//           value={value}
+//         />
+//         {label && (
+//           <Label
+//             {...labelProps}
+//             htmlFor={id}
+//             style={labelProps?.style ?? labelStyle}
+//             className={labelProps?.className ?? labelClassName}
+//             floating
+//             dense={dense}
+//             error={error}
+//             active={active || !!value}
+//             disabled={disabled}
+//             inactive={!!value}
+//           >
+//             {label}
+//           </Label>
+//         )}
+//       </TextFieldContainer>
+//       <Menu {...menuProps}>{children}</Menu>
+//     </FormMessageContainer>
+//   );
+// });
+
+export type SelectValue = number | string;
+
+export interface SelectOptionObject {
+  label: ReactNode;
+  value: SelectValue;
+  disabled?: boolean;
+}
+
+export interface SelectProps<Value extends SelectValue | SelectOptionObject>
+  extends FormFieldOptions,
+    HTMLAttributes<HTMLDivElement> {
+  /**
+   * @defaultValue `useId() + '-select'`
+   */
+  id?: string;
+
+  /**
+   * Optional placeholder text to display in the text field.
+   *
+   * @defaultValue `label ? " " : ""`
+   */
+  placeholder?: string;
+  value: Value;
+  onChange(nextValue: Value): void;
+  inputRef?: Ref<HTMLInputElement>;
+}
+
+export function Select<Value extends SelectValue | SelectOptionObject>(
+  props: SelectProps<Value>
+): ReactElement {
+  const {
+    id: propId,
+    label,
+    labelProps,
+    labelStyle,
+    labelClassName,
+    children,
+    inputRef,
+    value,
+    onChange,
+    dense = false,
+    error = false,
+    active = false,
+    disabled = false,
+    ...remaining
+  } = props;
+  const id = useEnsuredId(propId, "select");
+  const { visible, menuProps, toggleProps } = useDropdownMenu({
+    role: "listbox",
+    toggleRef: inputRef,
+    width: "equal",
+    transformOrigin: true,
+    anchor: BELOW_CENTER_ANCHOR,
+    onToggleKeyDown(event) {
+      if (event.key === " ") {
+        event.preventDefault();
+        event.stopPropagation();
+        event.currentTarget.click();
+      }
+    },
+  });
+
+  let inputLabel: ReactNode;
+  let inputValue: string | number;
+  if (typeof value === "number" || typeof value === "string") {
+    inputLabel = value;
+    inputValue = value;
+  } else {
+    inputLabel = value.label;
+    inputValue = value.value;
+  }
+
+  return (
+    <>
+      <TextFieldContainer
+        {...remaining}
+        {...toggleProps}
+        active={active || visible}
+        aria-haspopup="listbox"
+        id={id}
+        role="button"
+        tabIndex={0}
+        dense={dense}
+        error={error}
+        disabled={disabled}
+      >
+        <span id={`${id}-label`} className={textField()}>
+          {inputLabel}
+        </span>
+        <input id={id} type="hidden" value={inputValue} />
+        {label && (
+          <Label
+            {...labelProps}
+            htmlFor={id}
+            style={labelProps?.style ?? labelStyle}
+            className={cnb(
+              !!inputLabel &&
+                "rmd-label--floating-active rmd-label--floating-inactive",
+              labelProps?.className ?? labelClassName
+            )}
+            floating
+            dense={dense}
+            error={error}
+            active={active}
+            disabled={disabled}
+          >
+            {label}
+          </Label>
+        )}
+      </TextFieldContainer>
+      <Menu {...menuProps}>{children}</Menu>
+    </>
+  );
+}
