new file mode 100644
index 000000000..787be6181
--- /dev/null
+++ b/packages/menu/src2/MenuRenderer.tsx
@@ -0,0 +1,122 @@
+import { useAppSize } from "@react-md/core";
+import type { ReactElement, ReactNode, Ref } from "react";
+import { Menu } from "./Menu";
+import {
+  MenuConfigurationProvider,
+  useMenuConfiguration,
+} from "./MenuConfigurationProvider";
+import { MenuSheet } from "./MenuSheet";
+import {
+  BaseMenuRendererProps,
+  MenuListProps,
+  MenuProps,
+  MenuTransitionProps,
+} from "./types";
+
+/**
+ * @internal
+ * @remarks \@since 5.0.0
+ */
+export type MenuRendererProps = MenuProps &
+  BaseMenuRendererProps &
+  MenuListProps &
+  MenuTransitionProps & {
+    nodeRef: Ref<HTMLDivElement>;
+    children: ReactNode;
+  };
+
+/**
+ * This component conditionally renders either the `Menu` or `MenuSheet`
+ * component based on the current menu configuration.
+ *
+ * @internal
+ * @remarks \@since 5.0.0
+ */
+export function MenuRenderer(props: MenuRendererProps): ReactElement {
+  const {
+    nodeRef,
+    menuProps,
+    menuStyle,
+    menuClassName,
+    sheetProps,
+    sheetHeader: propSheetHeader,
+    sheetFooter: propSheetFooter,
+    sheetStyle,
+    sheetClassName,
+    sheetMenuProps,
+    children,
+    horizontal: propHorizontal,
+    renderAsSheet: propRenderAsSheet,
+    sheetPosition: propSheetPosition,
+    sheetVerticalSize: propSheetVerticalSize,
+    onClick,
+    onKeyDown,
+    ...remaining
+  } = props;
+
+  const { isPhone } = useAppSize();
+  const {
+    horizontal,
+    renderAsSheet,
+    sheetHeader,
+    sheetFooter,
+    sheetPosition,
+    sheetVerticalSize,
+  } = useMenuConfiguration({
+    horizontal: propHorizontal,
+    renderAsSheet: propRenderAsSheet,
+    sheetHeader: propSheetHeader,
+    sheetFooter: propSheetFooter,
+    sheetPosition: propSheetPosition,
+    sheetVerticalSize: propSheetVerticalSize,
+  });
+  const handlers = {
+    onClick,
+    onKeyDown,
+  };
+
+  const sheet =
+    renderAsSheet === true || (renderAsSheet === "phone" && isPhone);
+  return (
+    <MenuConfigurationProvider
+      horizontal={horizontal}
+      renderAsSheet={renderAsSheet}
+      sheetHeader={sheetHeader}
+      sheetFooter={sheetFooter}
+      sheetPosition={sheetPosition}
+      sheetVerticalSize={sheetVerticalSize}
+    >
+      {!sheet && (
+        <Menu
+          {...remaining}
+          {...menuProps}
+          {...handlers}
+          ref={nodeRef}
+          style={menuStyle}
+          className={menuClassName}
+          horizontal={horizontal}
+        >
+          {children}
+        </Menu>
+      )}
+      {sheet && (
+        <MenuSheet
+          {...remaining}
+          role="dialog"
+          {...sheetProps}
+          menuRef={nodeRef}
+          style={sheetStyle}
+          className={sheetClassName}
+          horizontal={horizontal}
+          header={sheetHeader}
+          footer={sheetFooter}
+          menuProps={{ ...sheetMenuProps, ...handlers }}
+          position={sheetPosition}
+          verticalSize={sheetVerticalSize}
+        >
+          {children}
+        </MenuSheet>
+      )}
+    </MenuConfigurationProvider>
+  );
+}
diff --git a/packages/menu/src2/MenuSheet.tsx b/packages/menu/src2/MenuSheet.tsx
