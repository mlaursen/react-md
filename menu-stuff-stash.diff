--- /dev/null
+++ b/packages/menu/src2/MenuProvider.tsx
@@ -0,0 +1,83 @@
+import { useEnsuredId, UseStateSetter } from "@react-md/core";
+import {
+  createContext,
+  MutableRefObject,
+  ReactElement,
+  ReactNode,
+  useContext,
+  useEffect,
+  useMemo,
+  useRef,
+} from "react";
+import { useMenuBarContext } from "./MenuBarProvider";
+
+export interface MenuState {
+  visible: boolean;
+  setVisible: UseStateSetter<boolean>;
+}
+
+export interface MenuContext extends MenuState {
+  toggleId: string;
+
+  /**
+   * The current focus index that is used for the keyboard movement and initial
+   * focus behavior on mount.
+   *
+   * If this is a boolean, it will update the initial focus behavior so that
+   * either the first (`true`) or last (`false`) are focused.
+   */
+  focusIndex: MutableRefObject<number | boolean>;
+
+  horizontal: boolean;
+}
+
+const context = createContext<MenuContext>({
+  toggleId: "",
+  visible: false,
+  setVisible() {
+    throw new Error("");
+  },
+  focusIndex: { current: -1 },
+  horizontal: false,
+});
+const { Provider } = context;
+context.displayName = "Menu";
+
+export function useMenuContext(): Readonly<MenuContext> {
+  return useContext(context);
+}
+
+export interface MenuProviderProps extends MenuState {
+  toggleId?: string;
+  horizontal: boolean;
+  children: ReactNode;
+}
+
+export function MenuProvider(props: MenuProviderProps): ReactElement {
+  const {
+    toggleId: propToggleId,
+    children,
+    visible,
+    setVisible,
+    horizontal,
+  } = props;
+  const focusIndex = useRef(0);
+  const toggleId = useEnsuredId(propToggleId, "menu-toggle");
+
+  const { root, activeId } = useMenuBarContext();
+  const value = useMemo<Readonly<MenuContext>>(
+    () => ({
+      horizontal,
+      toggleId,
+      visible,
+      setVisible,
+      focusIndex,
+    }),
+    [horizontal, setVisible, toggleId, visible]
+  );
+  useEffect(() => {
+    setVisible(toggleId === activeId);
+  }, [activeId, toggleId, root, setVisible]);
+
+  return <Provider value={value}>{children}</Provider>;
+}
