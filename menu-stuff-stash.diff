--- /dev/null
+++ b/packages/menu/src2/DropdownMenu.tsx
@@ -0,0 +1,229 @@
+import { FloatingActionButtonPosition } from "@react-md/button";
+import {
+  useFixedPositioning,
+  useScrollLock,
+  useUserInteractionMode,
+} from "@react-md/core";
+import { ReactElement, RefObject, useRef, useState } from "react";
+import { useMenuBarContext } from "./MenuBarProvider";
+import { MenuButton } from "./MenuButton";
+import { useMenuConfiguration } from "./MenuConfigurationProvider";
+import { MenuItemButton } from "./MenuItemButton";
+import { MenuProvider } from "./MenuProvider";
+import { MenuRenderer } from "./MenuRenderer";
+import {
+  DropdownMenuButtonProps,
+  DropdownMenuItemProps,
+  DropdownMenuVisibilityProps,
+} from "./types";
+import { getDefaultAnchor } from "./utils";
+
+export function DropdownMenu(props: DropdownMenuVisibilityProps): ReactElement {
+  const {
+    menuProps,
+    menuStyle,
+    menuClassName,
+    sheetProps,
+    sheetMenuProps,
+    sheetStyle,
+    sheetClassName,
+    sheetHeader: propSheetHeader,
+    sheetFooter: propSheetFooter,
+    renderAsSheet: propRenderAsSheet,
+    sheetPosition: propSheetPosition,
+    sheetVerticalSize: propSheetVerticalSize,
+    listStyle,
+    listClassName,
+    listProps,
+    appear,
+    enter,
+    exit,
+    timeout: propTimeout,
+    classNames,
+    anchor: propAnchor,
+    getFixedPositionOptions,
+    temporary,
+    onEnter,
+    onEntering,
+    onEntered,
+    onExit,
+    onExiting,
+    onExited,
+    horizontal: propHorizontal,
+    children,
+    preventScroll = false,
+    closeOnResize,
+    closeOnScroll,
+    iconRotatorProps: propIconRotatorProps,
+    disableFocusOnMount: propDisableFocusOnMount,
+    disableFocusOnUnmount: propDisableFocusOnUnmount,
+    visible: propVisible,
+    setVisible: propSetVisible,
+    defaultVisible = false,
+    ...remaining
+  } = props;
+
+  const {
+    horizontal,
+    sheetHeader,
+    sheetFooter,
+    renderAsSheet,
+    sheetPosition,
+    sheetVerticalSize,
+  } = useMenuConfiguration({
+    horizontal: propHorizontal,
+    sheetFooter: propSheetFooter,
+    sheetHeader: propSheetHeader,
+    renderAsSheet: propRenderAsSheet,
+    sheetPosition: propSheetPosition,
+    sheetVerticalSize: propSheetVerticalSize,
+  });
+
+  const [stateVisible, setStateVisible] = useState(defaultVisible);
+  const visible = propVisible ?? stateVisible;
+  const setVisible = propSetVisible || setStateVisible;
+  const toggleRef = useRef<HTMLButtonElement | HTMLLIElement>(null);
+  const mode = useUserInteractionMode();
+  const mouse = mode === "mouse";
+  const keyboard = mode === "keyboard";
+  const { root, menubar, menuitem, activeId, animatedOnce } =
+    useMenuBarContext();
+
+  const cancelUnmountFocus = useRef(false);
+  const disableTransition =
+    animatedOnce.current && menubar && !!activeId && (mouse || keyboard);
+  const timeout = propTimeout ?? (disableTransition ? 0 : undefined);
+
+  let iconRotatorProps = propIconRotatorProps;
+  if (disableTransition) {
+    iconRotatorProps = {
+      disableTransition: true,
+      ...propIconRotatorProps,
+    };
+  }
+
+  let floating: FloatingActionButtonPosition = null;
+  if (!menuitem) {
+    ({ floating = null } = remaining as DropdownMenuButtonProps);
+  }
+
+  const anchor = getDefaultAnchor({
+    anchor: propAnchor,
+    menubar,
+    menuitem: menuitem && !root,
+    floating,
+    horizontal,
+  });
+
+  let toggle: ReactElement;
+  if (menuitem) {
+    // see `DropdownMenuProps` about this typecast
+    const { buttonChildren, ...itemProps } = remaining as DropdownMenuItemProps;
+    const ref = toggleRef as RefObject<HTMLLIElement>;
+    toggle = (
+      <MenuItemButton
+        {...itemProps}
+        ref={ref}
+        iconRotatorProps={iconRotatorProps}
+      >
+        {buttonChildren}
+      </MenuItemButton>
+    );
+  } else {
+    // see `DropdownMenuProps` about this typecast
+    const { buttonChildren, ...buttonProps } =
+      remaining as DropdownMenuButtonProps;
+    const ref = toggleRef as RefObject<HTMLButtonElement>;
+    toggle = (
+      <MenuButton
+        {...buttonProps}
+        ref={ref}
+        iconRotatorProps={iconRotatorProps}
+      >
+        {buttonChildren}
+      </MenuButton>
+    );
+  }
+
+  useScrollLock(visible && preventScroll);
+  const { style, transitionOptions } = useFixedPositioning<
+    HTMLButtonElement | HTMLLIElement,
+    HTMLDivElement
+  >({
+    fixedTo: toggleRef,
+    anchor,
+    onEnter,
+    onEntering,
+    onEntered,
+    onExited,
+    transformOrigin: true,
+    getFixedPositionOptions,
+    onScroll(_event, data) {
+      if (!data.visible || closeOnScroll) {
+        cancelUnmountFocus.current = true;
+        setVisible(false);
+      }
+    },
+    onResize() {
+      if (closeOnResize) {
+        cancelUnmountFocus.current = true;
+        setVisible(false);
+      }
+    },
+  });
+
+  return (
+    <MenuProvider
+      toggleId={props.id}
+      visible={visible}
+      setVisible={setVisible}
+      horizontal={horizontal}
+    >
+      {toggle}
+      <MenuRenderer
+        {...transitionOptions}
+        menuProps={{
+          ...menuProps,
+          isFocusTypeDisabled: (type) => {
+            const disableFocusOnMount =
+              propDisableFocusOnMount ?? (mouse && timeout === 0);
+            const disableFocusOnUnmount =
+              propDisableFocusOnUnmount ??
+              ((mouse && timeout === 0) || cancelUnmountFocus.current);
+
+            return (
+              menuProps?.isFocusTypeDisabled?.(type) ||
+              (type === "mount" && disableFocusOnMount) ||
+              (type === "unmount" && disableFocusOnUnmount)
+            );
+          },
+        }}
+        menuStyle={{ ...style, ...menuStyle }}
+        menuClassName={menuClassName}
+        sheetProps={sheetProps}
+        sheetStyle={sheetStyle}
+        sheetClassName={sheetClassName}
+        sheetMenuProps={sheetMenuProps}
+        sheetHeader={sheetHeader}
+        sheetFooter={sheetFooter}
+        sheetPosition={sheetPosition}
+        sheetVerticalSize={sheetVerticalSize}
+        listStyle={listStyle}
+        listClassName={listClassName}
+        listProps={listProps}
+        horizontal={horizontal}
+        renderAsSheet={renderAsSheet}
+        temporary={temporary}
+        appear={appear}
+        enter={enter}
+        exit={exit}
+        onExit={onExit}
+        onExiting={onExiting}
+        timeout={timeout}
+        classNames={classNames}
+      >
+        {children}
+      </MenuRenderer>
+    </MenuProvider>
+  );
+}
diff --git a/packages/menu/src2/Menu.tsx b/packages/menu/src2/Menu.tsx
new file mode 100644
index 000000000..6520ed690
--- /dev/null
+++ b/packages/menu/src2/Menu.tsx
@@ -0,0 +1,198 @@
+/* eslint-disable jsx-a11y/click-events-have-key-events */
+import {
+  bem,
+  Portal,
+  useEnsuredId,
+  useFocusContainer,
+  useScaleTransition,
+} from "@react-md/core";
+import { List } from "@react-md/list";
+import { cnb } from "cnbuilder";
+import { forwardRef, useEffect, useRef } from "react";
+import { MenuBarProvider, useMenuBarContext } from "./MenuBarProvider";
+import { useMenuContext } from "./MenuProvider";
+import { MenuProps } from "./types";
+import { handleMenuClick, handleMenuFocus, handleMenuKeyDown } from "./utils";
+
+const neverTrue = (): boolean => false;
+
+const styles = bem("rmd-menu");
+
+export interface MenuClassNameOptions {
+  className?: string;
+  horizontal?: boolean;
+  elevated?: boolean;
+}
+
+export function menu(options: MenuClassNameOptions = {}): string {
+  const { className, horizontal, elevated } = options;
+
+  return cnb(styles({ horizontal, elevated }), className);
+}
+
+export const Menu = forwardRef<HTMLDivElement, MenuProps>(function Menu(
+  props,
+  ref
+) {
+  const {
+    id: propId,
+    "aria-label": ariaLabel,
+    "aria-labelledby": ariaLabelledBy,
+    children,
+    tabIndex = -1,
+    horizontal: propHorizontal,
+    disableElevation = false,
+    temporary = true,
+    className,
+    classNames,
+    timeout,
+    appear,
+    enter,
+    exit,
+    onEnter,
+    onEntering,
+    onEntered,
+    onExit,
+    onExiting,
+    onExited,
+    onClick,
+    onFocus,
+    onKeyDown,
+    listProps,
+    listStyle,
+    listClassName,
+    isFocusTypeDisabled = neverTrue,
+    disablePortal: propDisablePortal,
+    ...remaining
+  } = props;
+
+  const id = useEnsuredId(propId, "menu");
+  const {
+    toggleId,
+    visible,
+    setVisible,
+    focusIndex,
+    horizontal: menuHorizontal,
+  } = useMenuContext();
+  const horizontal = propHorizontal ?? menuHorizontal;
+  const { menuitem } = useMenuBarContext();
+
+  const cancelUnmountFocus = useRef(false);
+  const { nodeRef, eventHandlers, transitionOptions } = useFocusContainer({
+    activate: visible,
+    nodeRef: ref,
+    onEntering,
+    onEntered(appearing) {
+      onEntered?.(appearing);
+      cancelUnmountFocus.current = false;
+    },
+    onExiting,
+    onExited,
+    isFocusTypeDisabled(type) {
+      return (
+        isFocusTypeDisabled(type) ||
+        (type === "unmount" && cancelUnmountFocus.current)
+      );
+    },
+    onKeyDown: handleMenuKeyDown({
+      menuitem,
+      onKeyDown,
+      focusIndex,
+      setVisible,
+      horizontal,
+    }),
+  });
+
+  const { stage, rendered, disablePortal, elementProps } = useScaleTransition({
+    className: menu({
+      className,
+      elevated: !disableElevation,
+      horizontal,
+    }),
+    transitionIn: visible,
+    vertical: !horizontal,
+    temporary,
+    timeout,
+    classNames,
+    appear,
+    enter,
+    exit,
+    onEnter,
+    onExit,
+    ...transitionOptions,
+  });
+  useEffect(() => {
+    if (!visible) {
+      return;
+    }
+
+    const callback = (event: MouseEvent): void => {
+      const { target } = event;
+      if (
+        !(target instanceof HTMLElement) ||
+        !nodeRef.current?.contains(target)
+      ) {
+        setVisible(false);
+      }
+    };
+
+    // wait an animation frame so the initial click event that caused the menu
+    // to become visible does not immediately close the menu
+    const frame = window.requestAnimationFrame(() => {
+      window.addEventListener("click", callback);
+    });
+
+    return () => {
+      window.cancelAnimationFrame(frame);
+      window.removeEventListener("click", callback);
+    };
+  }, [nodeRef, setVisible, visible]);
+
+  return (
+    <Portal disabled={propDisablePortal ?? disablePortal}>
+      {rendered && (
+        <MenuBarProvider root={false} defaultActiveId={id}>
+          <div
+            hidden={temporary && stage === "exited"}
+            {...remaining}
+            {...elementProps}
+            {...eventHandlers}
+            aria-label={ariaLabel}
+            aria-labelledby={
+              ariaLabelledBy ?? typeof ariaLabel === "string"
+                ? undefined
+                : toggleId
+            }
+            id={id}
+            role="menu"
+            tabIndex={tabIndex}
+            onFocus={handleMenuFocus({ onFocus, focusIndex })}
+            onClick={handleMenuClick({
+              onClick,
+              setVisible,
+              cancelUnmountFocus,
+            })}
+          >
+            <List
+              {...listProps}
+              style={listStyle ?? listProps?.style}
+              className={listClassName || listProps?.className}
+              horizontal={horizontal}
+              onClick={(event) => {
+                listProps?.onClick?.(event);
+
+                // this makes it so you can click on the menu/list without
+                // closing the menu
+                if (event.target === event.currentTarget) {
+                  event.stopPropagation();
+                }
+              }}
+            >
+              {children}
+            </List>
+          </div>
+        </MenuBarProvider>
+      )}
+    </Portal>
+  );
+});
