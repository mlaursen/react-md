+/* eslint-disable jsx-a11y/click-events-have-key-events */
+import {
+  bem,
+  FocusContainerComponentProps,
+  KeyboardMovementProvider,
+  Portal,
+  PropsWithRef,
+  ScaleTransitionHookOptions,
+  useEnsuredId,
+  useEnsuredRef,
+  useFocusContainer,
+  useKeyboardMovementProvider,
+  useScaleTransition,
+  UseStateSetter,
+} from "@react-md/core";
+import { List, ListElement, ListProps } from "@react-md/list";
+import { cnb } from "cnbuilder";
+import {
+  CSSProperties,
+  forwardRef,
+  HTMLAttributes,
+  useEffect,
+  useRef,
+} from "react";
+import {
+  MenuBarProvider,
+  useMenuBarContext,
+  useMenuBarProvider,
+} from "./MenuBarProvider";
+import { useMenuVisibility } from "./MenuVisibilityProvider";
+import { MenuProps } from "./types";
+
+const styles = bem("rmd-menu");
+const neverTrue = (): boolean => false;
+
+export interface MenuClassNameOptions {
+  className?: string;
+  horizontal?: boolean;
+  elevated?: boolean;
+}
+
+export function menu(options: MenuClassNameOptions = {}): string {
+  const { className, horizontal, elevated } = options;
+
+  return cnb(styles({ horizontal, elevated }), className);
+}
+
+export const Menu = forwardRef<HTMLDivElement, MenuProps>(function Menu(
+  props,
+  propRef
+) {
+  const {
+    id: propId,
+    children,
+    tabIndex = -1,
+    horizontal: propHorizontal,
+    disableElevation = false,
+    temporary = true,
+    className,
+    classNames,
+    timeout,
+    appear,
+    enter,
+    exit,
+    onEnter,
+    onEntering,
+    onEntered,
+    onExit,
+    onExiting,
+    onExited,
+    listProps,
+    listStyle,
+    listClassName,
+    disablePortal: propDisablePortal,
+    onClick,
+    onFocus,
+    onKeyDown,
+    disableTransition: propDisableTransition,
+    isFocusTypeDisabled = neverTrue,
+    ...remaining
+  } = props;
+
+  const id = useEnsuredId(propId, "menu");
+  const { menubar, hoverTimeoutRef, enableHoverMode } = useMenuBarContext();
+  const { horizontal, toggleId, visible, setVisible } =
+    useMenuVisibility(propHorizontal);
+
+  const disableTransition =
+    propDisableTransition || hoverTimeoutRef.current === 0;
+
+  const cancelUnmountFocus = useRef(false);
+  const menuBarContext = useMenuBarProvider({
+    root: false,
+    defaultActiveId: id,
+  });
+  const [nodeRef, refCallback] = useEnsuredRef(propRef);
+  const { eventHandlers, transitionOptions } = useFocusContainer({
+    activate: visible,
+    nodeRef: refCallback,
+    disableTransition,
+    onEntering,
+    onEntered(appearing) {
+      onEntered?.(appearing);
+      // console.log("enableHoverMode:", enableHoverMode);
+      // enableHoverMode();
+      cancelUnmountFocus.current = false;
+    },
+    onExiting,
+    onExited,
+    isFocusTypeDisabled(type) {
+      return (
+        isFocusTypeDisabled(type) ||
+        (type === "unmount" && cancelUnmountFocus.current)
+      );
+    },
+    onKeyDown(event) {
+      onKeyDown?.(event);
+      switch (event.key) {
+        case "Escape":
+          event.stopPropagation();
+          setVisible(false);
+          break;
+        case "Tab":
+          event.preventDefault();
+          setVisible(false);
+          break;
+        case "ArrowRight":
+        case "ArrowLeft":
+          if (menubar && !horizontal) {
+            // don't prevent default and stop propagation so the menubar's focus
+            // behavior still activates
+            cancelUnmountFocus.current = true;
+            setVisible(false);
+          }
+          break;
+        case "ArrowUp":
+        case "ArrowDown":
+          if (menubar && horizontal) {
+            // don't prevent default and stop propagation so the menubar's focus
+            // behavior still activates
+            cancelUnmountFocus.current = true;
+            setVisible(false);
+          }
+          break;
+      }
+    },
+  });
+  const { stage, rendered, disablePortal, elementProps } = useScaleTransition({
+    className: menu({
+      className,
+      elevated: !disableElevation,
+      horizontal,
+    }),
+    transitionIn: visible,
+    vertical: !horizontal,
+    temporary,
+    timeout: disableTransition ? 0 : timeout,
+    classNames,
+    appear,
+    enter,
+    exit,
+    onEnter,
+    onExit,
+    ...transitionOptions,
+  });
+  const { movementProps, movementContext } = useKeyboardMovementProvider({
+    onFocus,
+    horizontal,
+    loopable: true,
+    searchable: true,
+    includeDisabled: true,
+    ...eventHandlers,
+  });
+  useEffect(() => {
+    if (!visible) {
+      return;
+    }
+
+    const callback = (_event: MouseEvent): void => {
+      // this won't be called if `event.stopPropagation()` is called
+      setVisible(false);
+    };
+
+    // wait an animation frame so the initial click event that caused the menu
+    // to become visible does not immediately close the menu
+    const frame = window.requestAnimationFrame(() => {
+      window.addEventListener("click", callback);
+    });
+
+    return () => {
+      window.cancelAnimationFrame(frame);
+      window.removeEventListener("click", callback);
+    };
+  }, [nodeRef, setVisible, visible]);
+
+  return (
+    <Portal disabled={propDisablePortal ?? disablePortal}>
+      {rendered && (
+        <MenuBarProvider value={menuBarContext}>
+          <KeyboardMovementProvider value={movementContext}>
+            <div
+              hidden={temporary && stage === "exited"}
+              {...remaining}
+              {...elementProps}
+              {...movementProps}
+              id={id}
+              role="menu"
+              tabIndex={tabIndex}
+              onClick={(event) => {
+                onClick?.(event);
+                if (event.target === event.currentTarget) {
+                  event.stopPropagation();
+                  return;
+                }
+
+                if (event.target instanceof HTMLElement) {
+                  cancelUnmountFocus.current = event.currentTarget.contains(
+                    event.target.closest("a")
+                  );
+                }
+              }}
+            >
+              <List
+                {...listProps}
+                style={listStyle ?? listProps?.style}
+                className={listClassName || listProps?.className}
+                horizontal={horizontal}
+                onClick={(event) => {
+                  listProps?.onClick?.(event);
+
+                  // this makes it so you can click on the menu/list without
+                  // closing the menu
+                  if (event.target === event.currentTarget) {
+                    event.stopPropagation();
+                  }
+                }}
+              >
+                {children}
+              </List>
+            </div>
+          </KeyboardMovementProvider>
+        </MenuBarProvider>
+      )}
+    </Portal>
+  );
+});
