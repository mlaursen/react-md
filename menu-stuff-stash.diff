+import type { DividerProps, VerticalDividerProps } from "@react-md/divider";
+import { divider, useVerticalDividerHeight } from "@react-md/divider";
+import type { HTMLAttributes } from "react";
+import { forwardRef } from "react";
+
+/** @remarks \@since 5.0.0 */
+export interface MenuItemSeparatorProps
+  extends HTMLAttributes<HTMLLIElement>,
+    Pick<DividerProps, "inset" | "vertical">,
+    Pick<VerticalDividerProps, "maxHeight"> {}
+
+/**
+ * This component renders a `<li role="separator">` with the divider styles. It
+ * will also automatically render itself vertically instead of horizontally if
+ * the menu is rendering horizontally.
+ *
+ * @remarks \@since 5.0.0 Renders as an `<li>` instead of a `<div>` or `<hr />`.
+ */
+export const MenuItemSeparator = forwardRef<
+  HTMLLIElement,
+  MenuItemSeparatorProps
+>(function MenuItemSeparator(props, ref) {
+  const {
+    style,
+    className,
+    maxHeight,
+    inset,
+    vertical: propVertical,
+    children,
+    ...remaining
+  } = props;
+
+  const horizontal = false;
+  // const horizontal = useMenuConfiguration().horizontal;
+  const vertical = propVertical ?? horizontal;
+  const heightProps = useVerticalDividerHeight({
+    ref,
+    style,
+    maxHeight: vertical ? maxHeight ?? 1 : 0,
+  });
+
+  return (
+    <li
+      {...remaining}
+      {...heightProps}
+      aria-orientation={vertical ? "vertical" : undefined}
+      role="separator"
+      className={divider({ inset: inset && !vertical, vertical, className })}
+    >
+      {children}
+    </li>
+  );
+});
diff --git a/packages/menu/src/MenuSheet.tsx b/packages/menu/src/MenuSheet.tsx
new file mode 100644
index 000000000..ebcfc265c
--- /dev/null
+++ b/packages/menu/src/MenuSheet.tsx
@@ -0,0 +1,154 @@
+import { useEnsuredRef } from "@react-md/core";
+import type { BaseSheetProps } from "@react-md/dialog";
+import { Sheet } from "@react-md/dialog";
+import type { HTMLAttributes, ReactElement, ReactNode, Ref } from "react";
+import { useEffect, useRef, useState } from "react";
+import { Menu } from "./Menu";
+import type { MenuListProps, MenuOrientationProps } from "./types";
+
+/** @remarks \@since 5.0.0 */
+export interface MenuSheetProps
+  extends Omit<BaseSheetProps, "visible" | "onRequestClose">,
+    MenuOrientationProps,
+    MenuListProps {
+  /** {@inheritDoc MenuConfiguration.sheetHeader} */
+  header?: ReactNode;
+  /** {@inheritDoc MenuConfiguration.sheetFooter} */
+  footer?: ReactNode;
+
+  /**
+   * The `Menu`s children.
+   */
+  children: ReactNode;
+
+  /**
+   * This should be the `menuRef` returned by the `useMenu` hook so that the
+   * menu can be focused on mount.
+   */
+  menuRef: Ref<HTMLDivElement>;
+
+  /**
+   * Any additional props that should be passed to the `Menu` component.
+   */
+  menuProps?: HTMLAttributes<HTMLDivElement>;
+}
+
+/**
+ * Implements a `Menu` using the `Sheet` component that probably shouldn't
+ * really be used externally.
+ *
+ * @remarks \@since 5.0.0
+ * @internal
+ */
+export function MenuSheet(props: MenuSheetProps): ReactElement {
+  const {
+    children,
+    header,
+    footer,
+    menuRef,
+    menuProps,
+    position = "bottom",
+    verticalSize = "touch",
+    onClick,
+    overlayProps,
+    listProps,
+    listStyle,
+    listClassName,
+    horizontal,
+    ...remaining
+  } = props;
+  const { "aria-label": ariaLabel } = props;
+  const [listNodeRef, listRef] = useEnsuredRef(listProps?.ref);
+  const toggleId = "";
+  const [visible, setVisible] = useState(false);
+  // const { visible, setVisible, toggleId } = useMenuContext();
+
+  // Since there is the possibility of other tab focusable elements within the
+  // sheet and the menu items are programmatically focused, the menu's tabIndex
+  // needs to be set to `-1` while one of the child menu items are focused. This
+  // allows Shift+Tab correctly focuses the previous focusable element within
+  // the sheet. Since `onFocus` and `onBlur` will be bubbled up to the menu
+  // widget each time a new MenuItem is focused, only disable the focused state
+  // if the blur event is fired without another focus event within an animation
+  // frame.
+  const [focused, setFocused] = useState(false);
+  const blurredFrame = useRef(0);
+  useEffect(() => {
+    return () => {
+      window.cancelAnimationFrame(blurredFrame.current);
+    };
+  }, []);
+
+  return (
+    <Sheet
+      aria-label={ariaLabel as string}
+      aria-labelledby={ariaLabel ? undefined : toggleId}
+      // allow any provided props to override the props above
+      {...remaining}
+      visible={visible}
+      onRequestClose={() => setVisible(false)}
+      overlayProps={{
+        ...overlayProps,
+        onClick: (event) => {
+          overlayProps?.onClick?.(event);
+
+          // prevent closing parent menus if the overlay element is clicked.
+          event.stopPropagation();
+          setVisible(false);
+        },
+      }}
+      position={position}
+      verticalSize={verticalSize}
+      onClick={(event) => {
+        onClick?.(event);
+
+        // Prevent closing parent sheet/menus if an element in the header or
+        // footer is clicked
+        if (
+          !(event.target instanceof HTMLElement) ||
+          !listNodeRef.current?.contains(event.target)
+        ) {
+          event.stopPropagation();
+        }
+      }}
+    >
+      {header}
+      <Menu
+        ref={menuRef}
+        tabIndex={focused ? -1 : 0}
+        {...menuProps}
+        listProps={{
+          ...listProps,
+          ref: listRef,
+        }}
+        listStyle={listStyle}
+        listClassName={listClassName}
+        horizontal={horizontal}
+        onFocus={(event) => {
+          menuProps?.onFocus?.(event);
+          window.cancelAnimationFrame(blurredFrame.current);
+          setFocused(true);
+        }}
+        onBlur={(event) => {
+          menuProps?.onBlur?.(event);
+          blurredFrame.current = window.requestAnimationFrame(() => {
+            setFocused(false);
+          });
+        }}
+        onKeyDown={(event) => {
+          // the tab keypress should use the sheet's behavior instead of
+          // closing the menus
+          if (event.key === "Tab") {
+            return;
+          }
+          menuProps?.onKeyDown?.(event);
+        }}
+        disablePortal
+        disableElevation
+      >
+        {children}
+      </Menu>
+      {footer}
+    </Sheet>
+  );
+}
