+import {
+  KeyboardMovementProvider,
+  useKeyboardMovementProvider,
+} from "@react-md/core";
+import { List, ListElement, ListProps } from "@react-md/list";
+import { forwardRef } from "react";
+import { MenuBarProvider, useMenuBarProvider } from "./MenuBarProvider";
+
+export interface MenuBarProps extends Omit<ListProps, "role" | "horizontal"> {
+  /**
+   * When this is provided and a number greater than 0, this will allow the
+   * menus to become visible on hover without clicking a `MenuItemButton`
+   * beforehand. Instead, hovering over a `MenuItemButton` for this time in
+   * milliseconds will display the `Menu`.
+   */
+  hoverTimeout?: number;
+
+  vertical?: boolean;
+}
+
+export const MenuBar = forwardRef<ListElement, MenuBarProps>(function MenuBar(
+  props,
+  ref
+) {
+  const {
+    vertical = false,
+    hoverTimeout,
+    children,
+    onFocus: propOnFocus,
+    onKeyDown: propOnKeyDown,
+    ...remaining
+  } = props;
+  const { movementProps, movementContext } = useKeyboardMovementProvider({
+    onFocus: propOnFocus,
+    onKeyDown: propOnKeyDown,
+    horizontal: !vertical,
+    loopable: true,
+    searchable: true,
+    includeDisabled: true,
+    tabIndexBehavior: "roving",
+  });
+  const menuBarContext = useMenuBarProvider({
+    root: true,
+    hoverTimeout,
+  });
+  return (
+    <MenuBarProvider value={menuBarContext}>
+      <KeyboardMovementProvider value={movementContext}>
+        <List
+          {...remaining}
+          {...movementProps}
+          ref={ref}
+          role="menubar"
+          horizontal={!vertical}
+        >
+          {children}
+        </List>
+      </KeyboardMovementProvider>
+    </MenuBarProvider>
+  );
+});
