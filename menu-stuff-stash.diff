@@ -0,0 +1,133 @@
+import {
+  bem,
+  KeyboardMovementProvider,
+  Portal,
+  useEnsuredId,
+  useKeyboardMovementProvider,
+  useScaleTransition,
+} from "@react-md/core";
+import { List } from "@react-md/list";
+import { cnb } from "cnbuilder";
+import { forwardRef } from "react";
+import type { MenuProps } from "./types";
+
+const styles = bem("rmd-menu");
+
+export interface MenuClassNameOptions {
+  className?: string;
+  horizontal?: boolean;
+  elevated?: boolean;
+}
+
+export function menu(options: MenuClassNameOptions = {}): string {
+  const { className, horizontal, elevated } = options;
+
+  return cnb(styles({ horizontal, elevated }), className);
+}
+
+export const Menu = forwardRef<HTMLDivElement, MenuProps>(function Menu(
+  props,
+  ref
+) {
+  const {
+    id: propId,
+    role = "menu",
+    children,
+    horizontal,
+    disableElevation = false,
+    temporary = true,
+    tabIndex = role === "listbox" ? 0 : -1,
+    className,
+    classNames,
+    timeout,
+    appear,
+    enter,
+    exit,
+    onEnter,
+    onEntering,
+    onEntered,
+    onExit,
+    onExiting,
+    onExited,
+    onFocus,
+    onKeyDown,
+    getDefaultFocusedIndex,
+    listProps,
+    listStyle,
+    listClassName,
+    visible,
+    disablePortal: propDisablePortal,
+    disableTransition,
+    ...remaining
+  } = props;
+
+  const id = useEnsuredId(propId, "menu");
+  const { stage, rendered, disablePortal, elementProps } = useScaleTransition({
+    nodeRef: ref,
+    className: menu({
+      className,
+      elevated: !disableElevation,
+      horizontal,
+    }),
+    transitionIn: visible,
+    vertical: !horizontal,
+    temporary,
+    timeout: disableTransition ? 0 : timeout,
+    classNames,
+    appear,
+    enter,
+    exit,
+    onEnter,
+    onEntering,
+    onEntered,
+    onExit,
+    onExiting,
+    onExited,
+  });
+  const { movementProps, movementContext } = useKeyboardMovementProvider({
+    onFocus,
+    onKeyDown,
+    horizontal,
+    loopable: true,
+    searchable: true,
+    includeDisabled: true,
+    tabIndexBehavior: role === "listbox" ? "virtual" : undefined,
+    getDefaultFocusedIndex,
+  });
+
+  return (
+    <Portal disabled={propDisablePortal ?? disablePortal}>
+      {rendered && (
+        <KeyboardMovementProvider value={movementContext}>
+          <div
+            hidden={!temporary && stage === "exited"}
+            {...remaining}
+            {...elementProps}
+            {...movementProps}
+            id={id}
+            role={role}
+            tabIndex={tabIndex}
+          >
+            <List
+              {...listProps}
+              style={listStyle ?? listProps?.style}
+              className={listClassName || listProps?.className}
+              horizontal={horizontal}
+              onClick={(event) => {
+                listProps?.onClick?.(event);
+
+                // this makes it so you can click on the menu/list without
+                // closing the menu
+                if (event.target === event.currentTarget) {
+                  event.stopPropagation();
+                }
+              }}
+            >
+              {children}
+            </List>
+          </div>
+        </KeyboardMovementProvider>
+      )}
+    </Portal>
+  );
+});
