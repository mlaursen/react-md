{
  "$schema": "https://json.schemastore.org/tsconfig.json",
  "extends": "./tsconfig.base.json",
  "include": ["**/*.ts", "**/*.tsx"],
  "compilerOptions": {
    "noEmit": true
  },
  "exclude": [
    "node_modules",
    "examples/*",
    "packages/*/node_modules",
    "packages/material-icons/*",
    "packages/codemod/*"
  ]
}
