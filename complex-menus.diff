@@ -0,0 +1,25 @@
+import { DropdownMenu, MenuItem } from "@react-md/menu";
+import type { ReactElement, ReactNode } from "react";
+
+interface InfiniteDropdownMenuProps {
+  index: number;
+  depth: number;
+  buttonChildren?: ReactNode;
+}
+
+export function InfiniteDropdownMenu({
+  index,
+  depth,
+  buttonChildren,
+}: InfiniteDropdownMenuProps): ReactElement {
+  return (
+    <DropdownMenu buttonChildren={buttonChildren ?? `Item ${index + 3}`}>
+      <MenuItem>Item 1</MenuItem>
+      <MenuItem>Item 2</MenuItem>
+      {Array.from({ length: 4 }, (_, i) => (
+        <InfiniteDropdownMenu key={i} depth={depth + 1} index={i} />
+      ))}
+      <MenuItem>Item 7</MenuItem>
+    </DropdownMenu>
+  );
+}
