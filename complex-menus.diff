+import { Button } from "@react-md/button";
+import { Typography } from "@react-md/core";
+import {
+  Dialog,
+  DialogContent,
+  DialogFooter,
+  DialogHeader,
+  DialogTitle,
+} from "@react-md/dialog";
+import type { NumberFieldWithMessageImplementation } from "@react-md/form";
+import { Form, TextField } from "@react-md/form";
+import type { ReactElement } from "react";
+import { InlineCode } from "src/components/Code";
+
+import styles from "./ConfigurationDialog.module.scss";
+
+export interface ConfigurationDialogProps
+  extends Pick<
+    NumberFieldWithMessageImplementation,
+    "fieldProps" | "error" | "reset"
+  > {
+  visible: boolean;
+  onRequestClose(): void;
+}
+
+export function ConfigurationDialog(
+  props: ConfigurationDialogProps
+): ReactElement {
+  const { visible, onRequestClose, error, reset, fieldProps } = props;
+  return (
+    <Dialog
+      aria-labelledby="configure-dialog-title"
+      modal
+      visible={visible}
+      onRequestClose={onRequestClose}
+      className={styles.dialog}
+    >
+      <DialogHeader>
+        <DialogTitle id="configure-dialog-title">
+          Configure Hover Timeout
+        </DialogTitle>
+      </DialogHeader>
+      <DialogContent>
+        <Form
+          onSubmit={onRequestClose}
+          onReset={() => {
+            reset();
+            onRequestClose();
+          }}
+        >
+          <TextField {...fieldProps} label="Hover Timeout" placeholder="0" />
+        </Form>
+        <Typography>
+          The amount of time the user must over over a menu in milliseconds
+          before the hover mode behavior is enabled.
+        </Typography>
+        <Typography>
+          If this is <InlineCode>undefined</InlineCode>, the user must click one
+          of the dropdown buttons before the hover mode is enabled.
+        </Typography>
+        <Typography>
+          If this is set to <InlineCode>0</InlineCode>, the menus will become
+          visible immediately on hover.
+        </Typography>
+      </DialogContent>
+      <DialogFooter>
+        <Button form="configure-form" type="reset" theme="warning">
+          Reset
+        </Button>
+        <Button
+          form="configure-form"
+          type="submit"
+          theme="primary"
+          disabled={error}
+        >
+          Confirm
+        </Button>
+      </DialogFooter>
+    </Dialog>
+  );
+}
