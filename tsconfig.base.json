{
  "$schema": "https://json.schemastore.org/tsconfig.json",
  "compilerOptions": {
    "baseUrl": ".",
    "target": "esnext",
    "module": "esnext",
    "sourceMap": true,
    "jsx": "react-jsx",
    "strict": true,
    "skipLibCheck": true,
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "downlevelIteration": true,
    "allowSyntheticDefaultImports": true,
    "noFallthroughCasesInSwitch": true,
    "forceConsistentCasingInFileNames": true,
    "lib": ["dom", "dom.iterable", "esnext"],
    "paths": {
      "alert": ["./packages/alert/src/index.ts"],
      "app-bar": ["./packages/app-bar/src/index.ts"],
      "autocomplete": ["./packages/autocomplete/src/index.ts"],
      "avatar": ["./packages/avatar/src/index.ts"],
      "badge": ["./packages/badge/src/index.ts"],
      "button": ["./packages/button/src/index.ts"],
      "card": ["./packages/card/src/index.ts"],
      "chip": ["./packages/chip/src/index.ts"],
      "dialog": ["./packages/dialog/src/index.ts"],
      "divider": ["./packages/divider/src/index.ts"],
      "elevation": ["./packages/elevation/src/index.ts"],
      "expansion-panel": ["./packages/expansion-panel/src/index.ts"],
      "form": ["./packages/form/src/index.ts"],
      "icon": ["./packages/icon/src/index.ts"],
      "layout": ["./packages/layout/src/index.ts"],
      "link": ["./packages/link/src/index.ts"],
      "list": ["./packages/list/src/index.ts"],
      "material-icons": ["./packages/material-icons/src/index.ts"],
      "media": ["./packages/media/src/index.ts"],
      "menu": ["./packages/menu/src/index.ts"],
      "overlay": ["./packages/overlay/src/index.ts"],
      "portal": ["./packages/portal/src/index.ts"],
      "progress": ["./packages/progress/src/index.ts"],
      "react-md": ["./packages/react-md/src/index.ts"],
      "sheet": ["./packages/sheet/src/index.ts"],
      "states": ["./packages/states/src/index.ts"],
      "table": ["./packages/table/src/index.ts"],
      "tabs": ["./packages/tabs/src/index.ts"],
      "theme": ["./packages/theme/src/index.ts"],
      "tooltip": ["./packages/tooltip/src/index.ts"],
      "transition": ["./packages/transition/src/index.ts"],
      "tree": ["./packages/tree/src/index.ts"],
      "typography": ["./packages/typography/src/index.ts"],
      "utils": ["./packages/utils/src/index.ts"]
    }
  }
}
