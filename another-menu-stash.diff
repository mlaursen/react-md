+import {
+  DEFAULT_HOVER_MODE_CONTEXT,
+  HoverModeConfiguration,
+  HoverModeContext,
+  useHoverModeProvider,
+} from "@react-md/core";
+import { createContext, useContext, useMemo } from "react";
+
+export interface MenuBarContext extends HoverModeContext {
+  root: boolean;
+  menubar: boolean;
+  menuitem: boolean;
+}
+
+const context = createContext<MenuBarContext>({
+  ...DEFAULT_HOVER_MODE_CONTEXT,
+  root: false,
+  menubar: false,
+  menuitem: false,
+});
+export const { Provider: MenuBarProvider } = context;
+
+export function useMenuBarContext(): Readonly<MenuBarContext> {
+  return useContext(context);
+}
+
+export interface MenuBarProviderOptions extends HoverModeConfiguration {
+  root?: boolean;
+}
+
+export function useMenuBarProvider(
+  options: MenuBarProviderOptions
+): Readonly<MenuBarContext> {
+  const {
+    root = true,
+    hoverTimeout,
+    disableTimeout,
+    defaultActiveId,
+  } = options;
+  const { menubar } = useMenuBarContext();
+  const hoverModeContext = useHoverModeProvider({
+    hoverTimeout,
+    disableTimeout,
+    defaultActiveId,
+  });
+
+  return useMemo<MenuBarContext>(
+    () => ({
+      ...hoverModeContext,
+      root,
+      menubar: root || menubar,
+      menuitem: true,
+    }),
+    [hoverModeContext, menubar, root]
+  );
+}
