@@ -0,0 +1,70 @@
+import {
+  useEnsuredId,
+  UseStateInitializer,
+  UseStateSetter,
+} from "@react-md/core";
+import { createContext, useContext, useMemo, useState } from "react";
+
+export interface MenuVisibilityState {
+  visible: boolean;
+  setVisible: UseStateSetter<boolean>;
+}
+
+export interface MenuVisibilityContext extends MenuVisibilityState {
+  toggleId: string;
+  horizontal: boolean;
+}
+
+const context = createContext<MenuVisibilityContext | undefined>(undefined);
+export const { Provider: MenuVisibilityProvider } = context;
+
+export interface MenuVisibilityProviderHookOptions
+  extends Partial<MenuVisibilityContext> {
+  defaultVisible?: UseStateInitializer<boolean>;
+}
+
+export function useMenuVisibilityProvider(
+  options?: MenuVisibilityProviderHookOptions & {
+    visible?: never;
+    setVisible?: never;
+  }
+): MenuVisibilityContext;
+export function useMenuVisibilityProvider(
+  options?: MenuVisibilityProviderHookOptions &
+    MenuVisibilityState & { defaultVisible?: never }
+): MenuVisibilityContext;
+export function useMenuVisibilityProvider(
+  options: MenuVisibilityProviderHookOptions = {}
+): Readonly<MenuVisibilityContext> {
+  const {
+    visible: propVisible,
+    setVisible: propSetVisible,
+    toggleId: propToggleId,
+    horizontal = false,
+    defaultVisible = false,
+  } = options;
+  const [localVisible, setLocalVisible] = useState(defaultVisible);
+  const toggleId = useEnsuredId(propToggleId, "menu-toggle");
+  const visible = propVisible ?? localVisible;
+  const setVisible = propSetVisible ?? setLocalVisible;
+
+  return useMemo(() => {
+    return {
+      visible,
+      setVisible,
+      toggleId,
+      horizontal,
+    };
+  }, [horizontal, setVisible, toggleId, visible]);
+}
+
+export function useMenuVisibility(
+  horizontal?: boolean
+): Readonly<MenuVisibilityContext> {
+  const value = useContext(context);
+  if (!value) {
+    throw new Error();
+  }
+
+  return { ...value, horizontal: horizontal ?? value.horizontal };
+}
