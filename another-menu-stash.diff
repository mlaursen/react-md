--- /dev/null
+++ b/packages/menu/src2/utils.ts
@@ -0,0 +1,323 @@
+import { FloatingActionButtonPosition } from "@react-md/button";
+import {
+  BELOW_CENTER_ANCHOR,
+  BELOW_INNER_LEFT_ANCHOR,
+  BOTTOM_INNER_LEFT_ANCHOR,
+  BOTTOM_INNER_RIGHT_ANCHOR,
+  CENTER_RIGHT_ANCHOR,
+  findMatchIndex,
+  getFocusableElements,
+  getSearchText,
+  loop,
+  PositionAnchor,
+  TOP_INNER_LEFT_ANCHOR,
+  TOP_INNER_RIGHT_ANCHOR,
+  TOP_RIGHT_ANCHOR,
+  UseStateSetter,
+} from "@react-md/core";
+import { ListElement } from "@react-md/list";
+import {
+  FocusEventHandler,
+  KeyboardEventHandler,
+  MouseEventHandler,
+  MutableRefObject,
+} from "react";
+
+const noop = (): void => {
+  // do nothing
+};
+
+/**
+ * @remarks \@since 5.0.0
+ * @internal
+ */
+interface DefaultAnchorOptions {
+  anchor?: PositionAnchor;
+  menubar: boolean;
+  menuitem: boolean;
+  floating: FloatingActionButtonPosition;
+  horizontal: boolean;
+}
+
+/**
+ * @remarks \@since 5.0.0
+ * @internal
+ */
+export const getDefaultAnchor = (
+  options: DefaultAnchorOptions
+): PositionAnchor => {
+  const { anchor, menubar, menuitem, floating, horizontal } = options;
+  if (anchor) {
+    return anchor;
+  }
+
+  switch (floating) {
+    case "bottom-left":
+      return BOTTOM_INNER_LEFT_ANCHOR;
+    case "bottom-right":
+      return BOTTOM_INNER_RIGHT_ANCHOR;
+    case "top-left":
+      return TOP_INNER_LEFT_ANCHOR;
+    case "top-right":
+      return TOP_INNER_RIGHT_ANCHOR;
+  }
+
+  if (menubar) {
+    return menuitem ? CENTER_RIGHT_ANCHOR : BELOW_INNER_LEFT_ANCHOR;
+  }
+
+  if (horizontal) {
+    return BELOW_CENTER_ANCHOR;
+  }
+
+  if (menuitem) {
+    return TOP_RIGHT_ANCHOR;
+  }
+
+  return TOP_INNER_RIGHT_ANCHOR;
+};
+
+export interface MenuButtonClickOptions<
+  E extends HTMLButtonElement | HTMLLIElement
+> {
+  onClick?: MouseEventHandler<E>;
+  menubar: boolean;
+  menuitem: boolean;
+  setVisible: UseStateSetter<boolean>;
+  focusIndex: MutableRefObject<number | boolean>;
+}
+
+export function handleMenuButtonClick<
+  E extends HTMLButtonElement | HTMLLIElement
+>(options: MenuButtonClickOptions<E>): MouseEventHandler<E> {
+  const { onClick = noop, menuitem, menubar, setVisible, focusIndex } = options;
+  return (event) => {
+    onClick(event);
+    if (event.isPropagationStopped()) {
+      return;
+    }
+
+    if (menuitem || menubar) {
+      // do not allow the default menu close behavior from
+      // triggering for parent menus
+      event.stopPropagation();
+    }
+
+    focusIndex.current = 0;
+    setVisible((prevVisible) => !prevVisible);
+  };
+}
+
+export interface MenuButtonKeyDownOptions<
+  E extends HTMLButtonElement | HTMLLIElement
+> {
+  onKeyDown?: KeyboardEventHandler<E>;
+  horizontal: boolean;
+  setVisible: UseStateSetter<boolean>;
+  focusIndex: MutableRefObject<number | boolean>;
+}
+
+export function handleMenuButtonKeyDown<
+  E extends HTMLButtonElement | HTMLLIElement
+>(options: MenuButtonKeyDownOptions<E>): KeyboardEventHandler<E> {
+  const { onKeyDown = noop, horizontal, setVisible, focusIndex } = options;
+  return (event) => {
+    onKeyDown(event);
+    if (event.isPropagationStopped()) {
+      return;
+    }
+
+    const { key } = event;
+    const isFocusFirst = key === (horizontal ? "ArrowDown" : "ArrowRight");
+    const isFocusLast = key === (horizontal ? "ArrowUp" : "ArrowLeft");
+    if (isFocusFirst || isFocusLast) {
+      event.preventDefault();
+      event.stopPropagation();
+
+      focusIndex.current = isFocusFirst;
+      setVisible(true);
+    }
+  };
+}
+
+export interface MenuClickOptions {
+  onClick?: MouseEventHandler<HTMLDivElement>;
+  setVisible: UseStateSetter<boolean>;
+  cancelUnmountFocus: MutableRefObject<boolean>;
+}
+
+export function handleMenuClick(
+  options: MenuClickOptions
+): MouseEventHandler<HTMLDivElement> {
+  const { onClick = noop, setVisible, cancelUnmountFocus } = options;
+  return (event) => {
+    onClick(event);
+    if (event.isPropagationStopped()) {
+      return;
+    }
+
+    // this makes it so you can click on the menu/list without
+    // closing the menu
+    if (event.target === event.currentTarget) {
+      event.stopPropagation();
+    }
+
+    if (event.target instanceof HTMLElement) {
+      cancelUnmountFocus.current = event.currentTarget.contains(
+        event.target.closest("a")
+      );
+    }
+
+    setVisible(false);
+  };
+}
+
+export interface MenuFocusOptions<E extends HTMLDivElement | ListElement> {
+  onFocus?: FocusEventHandler<E>;
+  focusIndex: MutableRefObject<number | boolean>;
+}
+
+export function handleMenuFocus<E extends HTMLDivElement | ListElement>(
+  options: MenuFocusOptions<E>
+): FocusEventHandler<E> {
+  const { onFocus = noop, focusIndex } = options;
+  return (event) => {
+    onFocus(event);
+    if (event.isPropagationStopped()) {
+      return;
+    }
+
+    event.stopPropagation();
+    const focusables = getFocusableElements(event.currentTarget, true);
+    let nextFocusIndex: number;
+    if (typeof focusIndex.current === "boolean") {
+      nextFocusIndex = focusIndex.current
+        ? 0
+        : Math.max(0, focusables.length - 1);
+    } else {
+      nextFocusIndex = focusIndex.current;
+    }
+
+    focusIndex.current = nextFocusIndex;
+    focusables[nextFocusIndex]?.focus();
+  };
+}
+
+export interface MenuKeyDownOptions<E extends HTMLDivElement | ListElement> {
+  menuitem?: boolean;
+  onKeyDown?: KeyboardEventHandler<E>;
+  horizontal?: boolean;
+  focusIndex: MutableRefObject<number | boolean>;
+  setVisible: UseStateSetter<boolean>;
+}
+
+export function handleMenuKeyDown<E extends HTMLDivElement | ListElement>(
+  options: MenuKeyDownOptions<E>
+): KeyboardEventHandler<E> {
+  const {
+    menuitem = false,
+    onKeyDown = noop,
+    horizontal = false,
+    focusIndex,
+    setVisible,
+  } = options;
+  return (event) => {
+    onKeyDown(event);
+    if (event.isPropagationStopped()) {
+      return;
+    }
+
+    const currentFocusIndex =
+      typeof focusIndex.current === "boolean" ? 0 : focusIndex.current;
+    const { key, altKey, ctrlKey, metaKey, shiftKey, currentTarget } = event;
+    if (key.length === 1 && key !== " " && !altKey && !ctrlKey && !metaKey) {
+      const focusables = getFocusableElements(currentTarget, true);
+
+      const nextFocusIndex = findMatchIndex({
+        value: key,
+        values: focusables.map((element) => getSearchText(element, true)),
+        // Shift key makes it so the first match is always used
+        startIndex: shiftKey ? -1 : currentFocusIndex,
+      });
+
+      event.preventDefault();
+      event.stopPropagation();
+      if (nextFocusIndex === -1 || focusIndex.current === nextFocusIndex) {
+        return;
+      }
+
+      focusIndex.current = nextFocusIndex;
+      focusables[nextFocusIndex]?.focus();
+      return;
+    }
+
+    const hide = (): void => setVisible(false);
+    switch (key) {
+      case "Escape":
+        // prevent parent components that have an "Escape" keypress event
+        // from being triggered as well
+        event.stopPropagation();
+        hide();
+        return;
+      case "Tab":
+        // since menus are portalled, tab index is kinda broke so just close
+        // the menu instead of doing default tab behavior
+        event.preventDefault();
+        if (!menuitem) {
+          // pressing the tab key should still cascade close all menus
+          event.stopPropagation();
+        }
+        hide();
+        return;
+      case "ArrowUp":
+        if (menuitem && horizontal) {
+          event.stopPropagation();
+          event.preventDefault();
+          hide();
+          return;
+        }
+        break;
+      case "ArrowLeft":
+        if (menuitem && !horizontal) {
+          event.stopPropagation();
+          event.preventDefault();
+          hide();
+          return;
+        }
+        break;
+    }
+
+    const isEnd = key === "End";
+    const isHome = key === "Home";
+    const isIncrement = key === (horizontal ? "ArrowRight" : "ArrowDown");
+    const isDecrement = key === (horizontal ? "ArrowLeft" : "ArrowUp");
+    if (!isHome && !isEnd && !isIncrement && !isDecrement) {
+      return;
+    }
+
+    event.preventDefault();
+    event.stopPropagation();
+
+    const focusables = getFocusableElements(currentTarget, true);
+    let nextFocusIndex = currentFocusIndex;
+    if (isHome) {
+      nextFocusIndex = 0;
+    } else if (isEnd) {
+      nextFocusIndex = focusables.length - 1;
+    } else {
+      nextFocusIndex = loop({
+        min: 0,
+        max: focusables.length - 1,
+        value: nextFocusIndex,
+        increment: isIncrement,
+      });
+    }
+
+    if (focusIndex.current === nextFocusIndex) {
+      return;
+    }
+
+    focusIndex.current = nextFocusIndex;
+    focusables[nextFocusIndex]?.focus();
+  };
+}
