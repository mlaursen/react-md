--- /dev/null
+++ b/packages/menu/src/useContextMenu.ts
@@ -0,0 +1,90 @@
+import type {
+  InitialCoords,
+  PositionAnchor,
+  UseStateSetter,
+} from "@react-md/core";
+import { BELOW_INNER_LEFT_ANCHOR } from "@react-md/core";
+import type { MouseEvent } from "react";
+import { useState } from "react";
+import type { MenuHookOptions, MenuImplementation } from "./useMenu";
+import { useMenu } from "./useMenu";
+
+export interface ContextMenuHookOptions<
+  MenuElement extends HTMLElement = HTMLDivElement
+> extends Omit<MenuHookOptions<HTMLElement, MenuElement>, "fixedTo"> {
+  onContextMenu?<E extends HTMLElement>(event: MouseEvent<E>): void;
+
+  /**
+   * @see {@link BELOW_INNER_LEFT_ANCHOR}
+   * @defaultValue `BELOW_INNER_LEFT_ANCHOR`
+   */
+  anchor?: PositionAnchor;
+
+  /**
+   * @defaultValue `true`
+   */
+  preventScroll?: boolean;
+}
+
+export interface ContextMenuImplementation<
+  MenuElement extends HTMLElement = HTMLDivElement
+> extends MenuImplementation<MenuElement> {
+  onContextMenu<E extends HTMLElement>(event: MouseEvent<E>): void;
+  setCoords: UseStateSetter<InitialCoords>;
+}
+
+export function useContextMenu<
+  MenuElement extends HTMLElement = HTMLDivElement
+>(
+  options: ContextMenuHookOptions<MenuElement> = {}
+): ContextMenuImplementation<MenuElement> {
+  const {
+    anchor = BELOW_INNER_LEFT_ANCHOR,
+    onContextMenu,
+    preventScroll = true,
+    isFocusTypeDisabled,
+    ...menuOptions
+  } = options;
+  const [coords, setCoords] = useState<InitialCoords>({});
+  const implementation = useMenu({
+    ...menuOptions,
+    ...coords,
+    anchor,
+    preventScroll,
+    isFocusTypeDisabled(type) {
+      if (typeof isFocusTypeDisabled === "function") {
+        return isFocusTypeDisabled(type);
+      }
+
+      return type === "unmount";
+    },
+  });
+  const { menuRef, setVisible } = implementation;
+
+  return {
+    ...implementation,
+    setCoords,
+    onContextMenu(event) {
+      onContextMenu?.(event);
+      if (
+        event.isPropagationStopped() ||
+        // make it so that if you right click the custom context menu, the
+        // browser's default context menu can appear (mostly for being able to
+        // inspect your custom context menu)
+        /* istanbul ignore next */
+        (event.target instanceof HTMLElement &&
+          menuRef.current?.contains(event.target))
+      ) {
+        return;
+      }
+
+      event.preventDefault();
+      event.stopPropagation();
+      setCoords({
+        initialX: event.clientX,
+        initialY: event.clientY,
+      });
+      setVisible(true);
+    },
+  };
+}
diff --git a/packages/menu/src/useDropdownMenu.ts b/packages/menu/src/useDropdownMenu.ts
new file mode 100644
index 000000000..351dae6f3
--- /dev/null
+++ b/packages/menu/src/useDropdownMenu.ts
@@ -0,0 +1,161 @@
+import { NonNullRef, useUserInteractionMode } from "@react-md/core";
+import { useEnsuredRef } from "@react-md/core";
+import {
+  KeyboardEventHandler,
+  MouseEventHandler,
+  Ref,
+  RefObject,
+  useEffect,
+} from "react";
+import { useRef } from "react";
+import { useMenuBarContext } from "./MenuBarProvider";
+import type { MenuHookOptions, MenuImplementation } from "./useMenu";
+import { useMenu } from "./useMenu";
+
+export interface DropdownMenuHookOptions<
+  ToggleElement extends HTMLElement = HTMLButtonElement,
+  MenuElement extends HTMLElement = HTMLDivElement
+> extends Omit<
+    MenuHookOptions<ToggleElement, MenuElement>,
+    "fixedTo" | "nodeRef" | "onCick" | "onKeyDown"
+  > {
+  /**
+   * Boolean if the toggle component is currently disabled which will prevent
+   * the arrow keys from opening a menuitem's menu.
+   *
+   * @defaultValue `false`
+   */
+  disabled?: boolean;
+  menuRef?: Ref<MenuElement>;
+  onMenuClick?: MouseEventHandler<MenuElement>;
+  onMenuKeyDown?: KeyboardEventHandler<MenuElement>;
+  toggleRef?: Ref<ToggleElement>;
+  onToggleClick?: MouseEventHandler<ToggleElement>;
+  onToggleKeyDown?: KeyboardEventHandler<ToggleElement>;
+  onToggleMouseEnter?: MouseEventHandler<ToggleElement>;
+  onToggleMouseLeave?: MouseEventHandler<ToggleElement>;
+}
+
+export interface DropdownMenuHookProvidedToggleProps<
+  ToggleElement extends HTMLElement
+> {
+  ref: Ref<ToggleElement>;
+  onClick: MouseEventHandler<ToggleElement>;
+  onKeyDown: KeyboardEventHandler<ToggleElement>;
+  onMouseEnter: MouseEventHandler<ToggleElement>;
+  onMouseLeave: MouseEventHandler<ToggleElement>;
+}
+
+export interface DropdownMenuImplementation<
+  ToggleElement extends HTMLElement = HTMLButtonElement,
+  MenuElement extends HTMLElement = HTMLDivElement
+> extends MenuImplementation<MenuElement> {
+  focusLast: NonNullRef<boolean>;
+  toggleRef: RefObject<ToggleElement>;
+  toggleProps: DropdownMenuHookProvidedToggleProps<ToggleElement>;
+}
+
+export function useDropdownMenu<
+  ToggleElement extends HTMLElement = HTMLButtonElement,
+  MenuElement extends HTMLElement = HTMLDivElement
+>(
+  options: DropdownMenuHookOptions<ToggleElement, MenuElement> = {}
+): DropdownMenuImplementation<ToggleElement, MenuElement> {
+  const {
+    menuRef,
+    onMenuClick,
+    onMenuKeyDown,
+    disabled = false,
+    toggleRef: propToggleRef,
+    onToggleClick,
+    onToggleKeyDown,
+    onToggleMouseEnter,
+    onToggleMouseLeave,
+    onExited,
+    ...menuOptions
+  } = options;
+
+  const [toggleRef, toggleRefCallback] = useEnsuredRef(propToggleRef);
+  const focusLast = useRef(false);
+  const menuImplemenentation = useMenu({
+    ...menuOptions,
+    fixedTo: toggleRef,
+    nodeRef: menuRef,
+    onClick: onMenuClick,
+    onKeyDown: onMenuKeyDown,
+    onExited() {
+      onExited?.();
+      focusLast.current = false;
+    },
+  });
+  const { setVisible } = menuImplemenentation;
+  const hoveringTimeoutRef = useRef<number | undefined>();
+  const mode = useUserInteractionMode();
+  const touch = mode === "touch";
+  const { menubar, hoverTimeoutRef, enableHoverMode, activeIdRef } =
+    useMenuBarContext();
+
+  useEffect(() => {
+    return () => {
+      window.clearTimeout(hoveringTimeoutRef.current);
+    };
+  }, []);
+
+  return {
+    ...menuImplemenentation,
+    focusLast,
+    toggleRef,
+    toggleProps: {
+      ref: toggleRefCallback,
+      onClick(event) {
+        console.log("CLICK");
+        onToggleClick?.(event);
+
+        setVisible((prevVisible) => !prevVisible);
+      },
+      onKeyDown(event) {
+        onToggleKeyDown?.(event);
+
+        if (disabled) {
+          return;
+        }
+
+        switch (event.key) {
+          case "ArrowUp":
+            event.preventDefault();
+            event.stopPropagation();
+            focusLast.current = true;
+            setVisible(true);
+            break;
+          case "ArrowDown":
+            event.preventDefault();
+            event.stopPropagation();
+            setVisible(true);
+            break;
+        }
+      },
+      onMouseEnter(event) {
+        onToggleMouseEnter?.(event);
+        if (disabled || !menubar || touch) {
+          return;
+        }
+
+        const { id } = event.currentTarget;
+        if (!id) {
+          throw new Error("Need id for hover mode");
+        }
+
+        if (typeof hoverTimeoutRef.current === "number") {
+          hoveringTimeoutRef.current = window.setTimeout(() => {
+            enableHoverMode(id);
+            setVisible(true);
+          }, hoverTimeoutRef.current);
+        }
+      },
+      onMouseLeave(event) {
+        onToggleMouseLeave?.(event);
+        window.clearTimeout(hoveringTimeoutRef.current);
+      },
+    },
+  };
+}
diff --git a/packages/menu/src/useMenu.ts b/packages/menu/src/useMenu.ts
new file mode 100644
index 000000000..3fe2a4b85
--- /dev/null
+++ b/packages/menu/src/useMenu.ts
@@ -0,0 +1,320 @@
+import type {
+  FixedPositioningOptions,
+  FixedPositioningTransitionCallbacks,
+  FocusContainerComponentProps,
+  FocusContainerEventHandlers,
+  FocusContainerTransitionOptions,
+  TransitionCallbacks,
+  UseStateInitializer,
+  UseStateSetter,
+} from "@react-md/core";
+import {
+  useEnsuredRef,
+  useFixedPositioning,
+  useFocusContainer,
+  useScrollLock,
+  useUserInteractionMode,
+} from "@react-md/core";
+import type {
+  CSSProperties,
+  KeyboardEventHandler,
+  MouseEvent,
+  MouseEventHandler,
+  Ref,
+  RefObject,
+} from "react";
+import { useCallback, useEffect, useRef, useState } from "react";
+import { useMenuBarContext } from "./MenuBarProvider";
+import { getDefaultAnchor } from "./utils";
+
+const neverTrue = (): boolean => false;
+
+export interface MenuHookOptions<
+  FixedToElement extends HTMLElement,
+  MenuElement extends HTMLElement = HTMLDivElement
+> extends Omit<TransitionCallbacks, "onExit">,
+    FocusContainerComponentProps,
+    Omit<FixedPositioningOptions<FixedToElement, MenuElement>, "fixedTo"> {
+  /**
+   * @defaultValue `"menu"`
+   */
+  role?: "menu" | "listbox";
+  fixedTo?: RefObject<FixedToElement>;
+  defaultVisible?: UseStateInitializer<boolean>;
+  horizontal?: boolean;
+  onClick?: MouseEventHandler<MenuElement>;
+  onKeyDown?: KeyboardEventHandler<MenuElement>;
+
+  /**
+   * @see {@link FixedPositioningOptions.transformOrigin}
+   * @defaultValue `true`
+   */
+  transformOrigin?: boolean;
+
+  /**
+   * Boolean if the menu should close if the page is scrolled. The default
+   * behavior is to just update the position of the menu relative to the menu
+   * button until it can no longer be visible within the viewport.
+   *
+   * @defaultValue `false`
+   */
+  closeOnScroll?: boolean;
+
+  /**
+   * Boolean if the page should no longer be scrollable while the menu is
+   * visible.
+   *
+   * @defaultValue `false`
+   */
+  preventScroll?: boolean;
+
+  /**
+   * Boolean if the menu should close instead of repositioning itself if the
+   * browser window is resized.
+   *
+   * @defaultValue `false`
+   */
+  closeOnResize?: boolean;
+}
+
+export interface MenuHookProvidedMenuProps<
+  MenuElement extends HTMLElement = HTMLDivElement
+> extends FixedPositioningTransitionCallbacks,
+    Omit<FocusContainerTransitionOptions<MenuElement>, "nodeRef">,
+    Required<FocusContainerEventHandlers<MenuElement>> {
+  role: "menu" | "listbox";
+  ref: Ref<MenuElement>;
+  style: CSSProperties | undefined;
+  visible: boolean;
+  horizontal: boolean;
+  disableTransition: boolean;
+  onClick: MouseEventHandler<MenuElement>;
+}
+
+export interface MenuImplementation<
+  MenuElement extends HTMLElement = HTMLDivElement
+> {
+  visible: boolean;
+  setVisible: UseStateSetter<boolean>;
+  menuRef: RefObject<MenuElement>;
+  menuProps: MenuHookProvidedMenuProps<MenuElement>;
+}
+
+export function useMenu<
+  FixedToElement extends HTMLElement,
+  MenuElement extends HTMLElement = HTMLDivElement
+>(
+  options: MenuHookOptions<FixedToElement, MenuElement> = {}
+): MenuImplementation<MenuElement> {
+  const {
+    role = "menu",
+    style: propStyle,
+    fixedTo: propFixedTo,
+    nodeRef: propNodeRef,
+    defaultVisible = false,
+    onEnter,
+    onEntering,
+    onEntered,
+    onExiting,
+    onExited,
+    onClick,
+    onKeyDown,
+    horizontal: propHorizontal,
+    disableTransition: propDisableTransition,
+    isFocusTypeDisabled = neverTrue,
+    getFixedPositionOptions,
+    onResize,
+    onScroll,
+    anchor,
+    vwMargin,
+    vhMargin,
+    xMargin,
+    yMargin,
+    width,
+    initialX,
+    initialY,
+    transformOrigin = true,
+    preventOverlap,
+    disableSwapping,
+    disableVHBounds,
+    closeOnResize = false,
+    closeOnScroll = false,
+    preventScroll = false,
+  } = options;
+  const fallbackFixedTo = useRef<FixedToElement>(null);
+  const fixedTo = propFixedTo ?? fallbackFixedTo;
+  const [menuNodeRef, menuRef] = useEnsuredRef(propNodeRef);
+  const {
+    menubar,
+    horizontal: contextHorizontal,
+    activeIdRef,
+    animatedOnceRef,
+    hoverTimeoutRef,
+  } = useMenuBarContext();
+
+  const mode = useUserInteractionMode();
+  const mouse = mode === "mouse";
+  const keyboard = mode === "keyboard";
+  const disableTransition =
+    propDisableTransition ??
+    (animatedOnceRef.current &&
+      menubar &&
+      !!activeIdRef.current &&
+      (mouse || keyboard));
+  const horizontal = propHorizontal ?? contextHorizontal;
+
+  const [visible, setVisible] = useState(defaultVisible);
+  const cancelUnmountFocus = useRef(false);
+  const { eventHandlers, transitionOptions } = useFocusContainer({
+    nodeRef: menuRef,
+    activate: visible,
+    onKeyDown(event) {
+      onKeyDown?.(event);
+      if (event.isPropagationStopped()) {
+        return;
+      }
+
+      switch (event.key) {
+        case "Escape":
+          // prevent parent components that have an "Escape" keypress event
+          // from being triggered as well
+          event.stopPropagation();
+          setVisible(false);
+          break;
+        case "Tab":
+          // since menus are portalled, tab index is kinda broke so just close
+          // the menu instead of doing default tab behavior
+          event.preventDefault();
+
+          // if (!menuitem)
+          // pressing the tab key should still cascade close all menus
+          event.stopPropagation();
+          setVisible(false);
+          break;
+      }
+    },
+    onEntering,
+    onEntered(appearing) {
+      onEntered?.(appearing);
+      cancelUnmountFocus.current = false;
+    },
+    onExiting,
+    onExited,
+    disableTransition,
+    isFocusTypeDisabled(type) {
+      const isHoverDisabled = mouse && hoverTimeoutRef.current === 0;
+      return (
+        isFocusTypeDisabled(type) ||
+        (type === "mount" && isHoverDisabled) ||
+        (type === "unmount" && (cancelUnmountFocus.current || isHoverDisabled))
+      );
+    },
+  });
+  const handleClick = useCallback(
+    (event: MouseEvent<MenuElement>) => {
+      onClick?.(event);
+
+      // this makes it so you can click on the menu/list without closing the
+      // menu
+      if (event.currentTarget === event.target) {
+        return;
+      }
+
+      // This might be a test only workaround since clicking links move focus
+      // somewhere else
+      if (event.target instanceof HTMLElement) {
+        cancelUnmountFocus.current = event.currentTarget.contains(
+          event.target.closest("a")
+        );
+      }
+    },
+    [onClick]
+  );
+  const { ref, style, callbacks } = useFixedPositioning({
+    style: propStyle,
+    fixedTo,
+    onEnter,
+    ...transitionOptions,
+    anchor: getDefaultAnchor({
+      anchor,
+      // TODO: Get
+      menubar: false,
+      menuitem: false,
+      horizontal,
+    }),
+    onScroll(event, data) {
+      onScroll?.(event, data);
+      if (!data.visible || closeOnScroll) {
+        cancelUnmountFocus.current = true;
+        setVisible(false);
+      }
+    },
+    onResize(event) {
+      onResize?.(event);
+      if (closeOnResize) {
+        cancelUnmountFocus.current = true;
+        setVisible(false);
+      }
+    },
+    vwMargin,
+    vhMargin,
+    xMargin,
+    yMargin,
+    width,
+    transformOrigin,
+    preventOverlap,
+    disableSwapping,
+    disableVHBounds,
+    initialX,
+    initialY,
+    getFixedPositionOptions,
+  });
+  useScrollLock(visible && preventScroll);
+
+  useEffect(() => {
+    if (!visible) {
+      return;
+    }
+
+    const callback = (event: globalThis.MouseEvent): void => {
+      // if the user clicks outside of the menu to close it, the toggle button
+      // should not be focused. instead the nearest focusable element from the
+      // click event should be focused when Tab or Shoft + tab is pressed
+      cancelUnmountFocus.current =
+        !(event.target instanceof HTMLElement) ||
+        !event.target.closest(`[role="${role}"]`);
+
+      // this won't be called if `event.stopPropagation()` is called
+      setVisible(false);
+    };
+
+    // wait an animation frame so the initial click event that caused the menu
+    // to become visible does not immediately close the menu
+    const frame = window.requestAnimationFrame(() => {
+      window.addEventListener("click", callback);
+    });
+
+    return () => {
+      window.cancelAnimationFrame(frame);
+      window.removeEventListener("click", callback);
+    };
+  }, [role, visible]);
+
+  return {
+    visible,
+    setVisible,
+    menuRef: menuNodeRef,
+    menuProps: {
+      ref,
+      role,
+      style,
+      visible,
+      horizontal,
+      ...callbacks,
+      ...eventHandlers,
+      onClick: handleClick,
+      onExiting: transitionOptions.onExiting,
+      disableTransition,
+    },
+  };
+}
diff --git a/packages/menu/src/utils.ts b/packages/menu/src/utils.ts
new file mode 100644
index 000000000..eb6cf035e
--- /dev/null
+++ b/packages/menu/src/utils.ts
@@ -0,0 +1,62 @@
+import type { FloatingActionButtonPosition } from "@react-md/button";
+import type { PositionAnchor } from "@react-md/core";
+import {
+  BELOW_CENTER_ANCHOR,
+  BELOW_INNER_LEFT_ANCHOR,
+  BOTTOM_INNER_LEFT_ANCHOR,
+  BOTTOM_INNER_RIGHT_ANCHOR,
+  CENTER_RIGHT_ANCHOR,
+  TOP_INNER_LEFT_ANCHOR,
+  TOP_INNER_RIGHT_ANCHOR,
+  TOP_RIGHT_ANCHOR,
+} from "@react-md/core";
+
+/**
+ * @remarks \@since 5.0.0
+ * @internal
+ */
+interface DefaultAnchorOptions {
+  anchor?: PositionAnchor;
+  menubar: boolean;
+  menuitem: boolean;
+  floating?: FloatingActionButtonPosition;
+  horizontal: boolean;
+}
+
+/**
+ * @remarks \@since 5.0.0
+ * @internal
+ */
+export const getDefaultAnchor = (
+  options: DefaultAnchorOptions
+): PositionAnchor => {
+  const { anchor, menubar, menuitem, floating, horizontal } = options;
+  if (anchor) {
+    return anchor;
+  }
+
+  switch (floating) {
+    case "bottom-left":
+      return BOTTOM_INNER_LEFT_ANCHOR;
+    case "bottom-right":
+      return BOTTOM_INNER_RIGHT_ANCHOR;
+    case "top-left":
+      return TOP_INNER_LEFT_ANCHOR;
+    case "top-right":
+      return TOP_INNER_RIGHT_ANCHOR;
+  }
+
+  if (menubar) {
+    return menuitem ? CENTER_RIGHT_ANCHOR : BELOW_INNER_LEFT_ANCHOR;
+  }
+
+  if (horizontal) {
+    return BELOW_CENTER_ANCHOR;
+  }
+
+  if (menuitem) {
+    return TOP_RIGHT_ANCHOR;
+  }
+
+  return TOP_INNER_RIGHT_ANCHOR;
+};
diff --git a/packages/menu/src2/DropdownMenu.tsx b/packages/menu/src2/DropdownMenu.tsx
