+++ b/packages/menu/src2/MenuButton.tsx
@@ -0,0 +1,75 @@
+import { Button } from "@react-md/button";
+import { IconRotator, useIcon } from "@react-md/icon";
+import { forwardRef } from "react";
+import { useMenuContext } from "./MenuProvider";
+import type { MenuButtonProps } from "./types";
+import { handleMenuButtonClick, handleMenuButtonKeyDown } from "./utils";
+
+const noop = (): void => {
+  // do nothing
+};
+
+/**
+ * This is just an internal component that handles rendering the button for a
+ * `DropdownMenu` with a conditional dropdown icon.
+ *
+ * @internal
+ * @remarks \@since 5.0.0
+ */
+export const MenuButton = forwardRef<HTMLButtonElement, MenuButtonProps>(
+  function MenuButton(props, ref) {
+    const {
+      id,
+      onClick = noop,
+      onKeyDown = noop,
+      icon: propIcon,
+      iconAfter = true,
+      iconRotatorProps,
+      floating,
+      buttonType = floating ? "icon" : "text",
+      disableDropdownIcon = buttonType === "icon",
+      children,
+      ...remaining
+    } = props;
+    const { toggleId, visible, setVisible, focusIndex } = useMenuContext();
+    const dropdownIcon = useIcon("dropdown", propIcon);
+    let icon = propIcon;
+    if (!disableDropdownIcon) {
+      icon = (
+        <IconRotator {...iconRotatorProps} rotated={visible}>
+          {dropdownIcon}
+        </IconRotator>
+      );
+    }
+
+    return (
+      <Button
+        {...remaining}
+        id={id ?? toggleId}
+        ref={ref}
+        buttonType={buttonType}
+        floating={floating}
+        onClick={handleMenuButtonClick({
+          onClick,
+          // MenuButtons can never be rendered as menuitems or within a MenuBar
+          menubar: false,
+          menuitem: false,
+          setVisible,
+          focusIndex,
+        })}
+        onKeyDown={handleMenuButtonKeyDown({
+          onKeyDown,
+          setVisible,
+          focusIndex,
+          // MenuButtons can never be rendered as menuitems or within a MenuBar
+          menubar: false,
+          horizontal: false,
+        })}
+      >
+        {!iconAfter && icon}
+        {children}
+        {iconAfter && icon}
+      </Button>
+    );
+  }
+);
