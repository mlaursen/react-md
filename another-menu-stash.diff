--- /dev/null
+++ b/packages/menu/src2/MenuBar.tsx
@@ -0,0 +1,77 @@
+import {
+  LabelRequiredForA11y,
+  PROGRAMMATICALLY_FOCUSABLE,
+} from "@react-md/core";
+import { List, ListProps } from "@react-md/list";
+import { createContext, ReactElement, useContext, useState } from "react";
+import {
+  HoverableMenuBar,
+  MenuBarProvider,
+  useMenuBarContext,
+} from "./MenuBarProvider";
+
+/**
+ * This context is used to implement the "roving tab index" behavior
+ *
+ * @internal
+ * @remarks \@since 5.0.0
+ */
+const context = createContext("");
+context.displayName = "MenuBarFocusId";
+const { Provider } = context;
+
+/** @remarks \@since 5.0.0 */
+export function useMenuBarWidgetFocusId(): string {
+  return useContext(context);
+}
+
+export interface MenuBarProps
+  extends Omit<ListProps, "role" | "horizontal">,
+    HoverableMenuBar {}
+
+export function MenuBar(
+  props: LabelRequiredForA11y<MenuBarProps>
+): ReactElement {
+  const { tabIndex, onFocus, onKeyDown, children, hoverTimeout, ...remaining } =
+    props;
+
+  const { setActiveId } = useMenuBarContext();
+  const [focusId, setFocusId] = useState("");
+  return (
+    <MenuBarProvider hoverTimeout={hoverTimeout}>
+      <Provider value={focusId}>
+        <List
+          {...remaining}
+          role="menubar"
+          horizontal
+          tabIndex={tabIndex ?? focusId ? -1 : 0}
+          onFocus={(event) => {
+            onFocus?.(event);
+            if (event.target === event.currentTarget) {
+              const firstElement =
+                event.currentTarget.querySelector<HTMLElement>(
+                  PROGRAMMATICALLY_FOCUSABLE
+                );
+              if (!firstElement) {
+                return;
+              }
+
+              setActiveId(firstElement.id);
+              firstElement.focus();
+              return;
+            }
+
+            const { id } = event.target;
+            setFocusId(id);
+            setActiveId((prevActiveId) => (prevActiveId ? id : ""));
+          }}
+          onKeyDown={(event) => {
+            onKeyDown?.(event);
+          }}
+        >
+          {children}
+        </List>
+      </Provider>
+    </MenuBarProvider>
+  );
+}
diff --git a/packages/menu/src2/MenuBarProvider.tsx b/packages/menu/src2/MenuBarProvider.tsx
new file mode 100644
index 000000000..e5237023a
--- /dev/null
+++ b/packages/menu/src2/MenuBarProvider.tsx
@@ -0,0 +1,179 @@
+import { NonNullRef, UseStateSetter } from "@react-md/core";
+import {
+  createContext,
+  ReactElement,
+  ReactNode,
+  useContext,
+  useMemo,
+  useRef,
+  useState,
+} from "react";
+
+const noop = (): void => {
+  // do nothing
+};
+
+/**
+ * @internal
+ * @remarks \@since 5.0.0
+ */
+export interface HoverableMenuBar {
+  /**
+   * When this is provided and a number greater than 0, this will allow the
+   * menus to become visible on hover without clicking a `MenuItemButton`
+   * beforehand. Instead, hovering over a `MenuItemButton` for this time in
+   * milliseconds will display the `Menu`.
+   */
+  hoverTimeout?: number;
+}
+
+/**
+ * @internal
+ * @remarks \@since 5.0.0
+ */
+export interface MenuBarContext extends HoverableMenuBar {
+  /**
+   * Boolean if the `MenuBar` is the top-most `MenuBar`. This is just used so
+   * that the top-most `DropdownMenu` can render as a `MenuItemButton` instead
+   * of a `MenuButton` while maintaining the dropdown icon and keyboard behavior
+   * of a `MenuButton`.
+   */
+  root: boolean;
+
+  /**
+   * Boolean if the `MenuBar` functionality is enabled.
+   */
+  menubar: boolean;
+
+  /**
+   * This isn't tied directly to a `MenuBar`, but this is used to determine if
+   * there is a parent `Menu` so the `DropdownMenu` can be rendered as a
+   * `MenuItemButton` instead of a `MenuButton`.
+   */
+  menuitem: boolean;
+
+  /**
+   * This is the current DOM id for the `MenuButton` or `MenuItemButton` this is
+   * currently visible within the `MenuBar`. If the `MenuBar` behavior has not
+   * been enabled or no `Menu` are visible, this will be an empty string;
+   */
+  activeId: string;
+
+  /**
+   * This is used to manually set the {@link activeId} based on menu visibility.
+   */
+  setActiveId: UseStateSetter<string>;
+
+  /**
+   * Boolean if at least one menu has finished the enter animation. This is used
+   * to disable repeating the enter animation once the user is in hover mode
+   * since it is distracting to have to wait `0.2ms` each time a new menu gains
+   * visibility.
+   *
+   * @remarks \@since 6.0.0 This changed to a `RefObject<boolean>` to prevent
+   * unneeded rerenders.
+   */
+  animatedOnce: NonNullRef<boolean>;
+
+  /**
+   * This should be called with the menu's `onEntered` option so that the
+   * {@link animatedOnce} flag can be set to `true`. Once the {@link activeId}
+   * becomes an empty string (no visible menus), this should be called again
+   * with `false` so that the menu animations are visible.
+   *
+   * @remarks \@since 6.0.0 This changed to a simple setter instead of a
+   * `Dispatch<SetStateAction<boolean>>`
+   */
+  setAnimatedOnce(animatedOnce: boolean): void;
+}
+
+const context = createContext<MenuBarContext>({
+  root: false,
+  menubar: false,
+  menuitem: false,
+  activeId: "",
+  setActiveId: noop,
+  animatedOnce: { current: false },
+  setAnimatedOnce: noop,
+});
+context.displayName = "MenuBar";
+const { Provider } = context;
+
+/**
+ * @internal
+ * @remarks \@since 5.0.0
+ */
+export function useMenuBarContext(): Readonly<MenuBarContext> {
+  return useContext(context);
+}
+
+/**
+ * @internal
+ * @remarks \@since 5.0.0
+ */
+export interface MenuBarProviderProps extends HoverableMenuBar {
+  /**
+   * This should be set to `false` if this is a child of another `Menu`.
+   *
+   * @defaultValue `true`
+   * @see {@link MenuBarContext.root}
+   */
+  root?: boolean;
+
+  /**
+   * This is used so that when the user is moving through the `MenuBar` while a
+   * menu is opened, pressing the `ArrowLeft` or `ArrowRight` key will:
+   * - close the current menu
+   * - focus the next menu's toggle element
+   * - open the next menu's toggle element
+   * - move focus to the first menu item
+   *
+   * This should be set to the `Menu`'s id in that the example above. Otherwise
+   * it should be omitted.
+   *
+   * @defaultValue `""`
+   */
+  defaultActiveId?: string;
+
+  children: ReactNode;
+}
+
+/**
+ * @internal
+ * @remarks \@since 5.0.0
+ */
+export function MenuBarProvider(props: MenuBarProviderProps): ReactElement {
+  const { children, root = true, defaultActiveId = "", hoverTimeout } = props;
+  const { menubar } = useMenuBarContext();
+  const [activeId, setActiveId] = useState(defaultActiveId);
+  const animatedOnce = useRef(!!defaultActiveId);
+  const value = useMemo<MenuBarContext>(
+    () => ({
+      root,
+      menubar: root || menubar,
+      menuitem: true,
+      // everything below this might be able to be ported into a better hover mode provider?
+      activeId,
+      setActiveId(value) {
+        setActiveId((prevActiveId) => {
+          const nextValue =
+            typeof value === "function" ? value(prevActiveId) : value;
+
+          if (!nextValue) {
+            animatedOnce.current = false;
+          }
+
+          return nextValue;
+        });
+      },
+      hoverTimeout,
+      animatedOnce,
+      setAnimatedOnce(nextValue) {
+        animatedOnce.current = nextValue;
+      },
+    }),
+    [activeId, animatedOnce, hoverTimeout, menubar, root]
+  );
+
+  return <Provider value={value}>{children}</Provider>;
+}
diff --git a/packages/menu/src2/MenuButton.tsx b/packages/menu/src2/MenuButton.tsx
