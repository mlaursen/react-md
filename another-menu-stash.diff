@@ -0,0 +1,115 @@
+import { useUserInteractionMode } from "@react-md/core";
+import { IconRotator, useIcon } from "@react-md/icon";
+import { forwardRef, useEffect, useRef } from "react";
+import { useMenuBarContext } from "./MenuBarProvider";
+import { MenuItem } from "./MenuItem";
+import { useMenuContext } from "./MenuProvider";
+import type { MenuItemButtonProps } from "./types";
+import { handleMenuButtonClick, handleMenuButtonKeyDown } from "./utils";
+
+const noop = (): void => {
+  // do nothing
+};
+
+/**
+ * This is just an internal component that handles rendering a submenu as a
+ * menuitem for a `DropdownMenu` with a conditional dropdown icon.
+ *
+ * @internal
+ * @remarks \@since 5.0.0
+ */
+export const MenuItemButton = forwardRef<HTMLLIElement, MenuItemButtonProps>(
+  function MenuItemButton(props, ref) {
+    const {
+      id: propId,
+      children,
+      rightAddon: propRightAddon,
+      disableDropdownIcon = typeof propRightAddon !== "undefined",
+      tabIndex,
+      iconRotatorProps,
+      onClick = noop,
+      onKeyDown = noop,
+      onMouseEnter = noop,
+      onMouseLeave = noop,
+      ...remaining
+    } = props;
+
+    const { disabled } = props;
+    const touch = useUserInteractionMode() === "touch";
+    const { root, menubar, activeId, setActiveId, hoverTimeout } =
+      useMenuBarContext();
+    const { toggleId, visible, setVisible, focusIndex, horizontal } =
+      useMenuContext();
+    const id = propId ?? toggleId;
+    const focusId = "";
+    // const focusId = useMenuBarWidgetFocusId();
+    const dropdownIcon = useIcon(root ? "dropdown" : "forward");
+
+    let rightAddon = propRightAddon;
+    if (!disableDropdownIcon) {
+      rightAddon = (
+        <IconRotator {...iconRotatorProps} rotated={visible}>
+          {dropdownIcon}
+        </IconRotator>
+      );
+    }
+    const timeout = useRef(0);
+    useEffect(() => {
+      return () => {
+        window.clearTimeout(timeout.current);
+      };
+    }, []);
+
+    return (
+      <MenuItem
+        {...remaining}
+        id={id}
+        ref={ref}
+        rightAddon={rightAddon}
+        tabIndex={tabIndex ?? (root && id === focusId ? 0 : -1)}
+        onClick={handleMenuButtonClick({
+          onClick,
+          menubar,
+          menuitem: true,
+          setVisible,
+          focusIndex,
+          // setActiveId,
+        })}
+        onKeyDown={handleMenuButtonKeyDown({
+          onKeyDown,
+          setVisible,
+          focusIndex,
+          horizontal: (root && menubar) || horizontal,
+        })}
+        onMouseEnter={(event) => {
+          onMouseEnter(event);
+          if (
+            event.isPropagationStopped() ||
+            disabled ||
+            !menubar ||
+            !activeId ||
+            touch
+          ) {
+            return;
+          }
+
+          if (typeof hoverTimeout === "number") {
+            timeout.current = window.setTimeout(() => {
+              setActiveId(id);
+            }, hoverTimeout);
+            return;
+          }
+          setActiveId(id);
+        }}
+        onMouseLeave={(event) => {
+          onMouseLeave(event);
+          if (event.isPropagationStopped()) {
+            return;
+          }
+        }}
+      >
+        {children}
+      </MenuItem>
+    );
+  }
+);
