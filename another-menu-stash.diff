+import { Button, ButtonProps } from "@react-md/button";
+import { useEnsuredId } from "@react-md/core";
+import { IconRotator, IconRotatorProps, useIcon } from "@react-md/icon";
+import type { ReactNode } from "react";
+import { forwardRef } from "react";
+import { useMenuBarContext } from "./MenuBarProvider";
+import { useMenuVisibility } from "./MenuVisibilityProvider";
+
+/** @remarks \@since 5.0.0 */
+export type MenuButtonIconRotatorProps = Omit<
+  IconRotatorProps,
+  "children" | "rotated"
+>;
+
+export interface BaseMenuButtonProps {
+  id?: string;
+
+  /**
+   * Any additional props to pass to the {@link IconRotator} component that
+   * surrounds the {@link buttonChildren}
+   */
+  iconRotatorProps?: Readonly<MenuButtonIconRotatorProps>;
+
+  /**
+   * Boolean if the dropdown icon should be included with the button children.
+   *
+   * @defaultValue `buttonType === "icon"`
+   */
+  disableDropdownIcon?: boolean;
+}
+
+export interface MenuButtonProps extends ButtonProps, BaseMenuButtonProps {
+  icon?: ReactNode;
+  iconAfter?: boolean;
+
+  // I want this to be inherited
+  visible?: boolean;
+}
+
+export const MenuButton = forwardRef<HTMLButtonElement, MenuButtonProps>(
+  function MenuButton(props, ref) {
+    const {
+      id: propId,
+      icon: propIcon,
+      iconAfter = false,
+      iconRotatorProps,
+      floating = null,
+      theme = floating ? "secondary" : "clear",
+      themeType = floating ? "contained" : "flat",
+      buttonType = floating ? "icon" : "text",
+      disableDropdownIcon = buttonType === "icon",
+      children,
+      onClick,
+      onKeyDown,
+      ...remaining
+    } = props;
+
+    const { menubar, menuitem } = useMenuBarContext();
+    const { visible, setVisible } = useMenuVisibility();
+    const id = useEnsuredId(propId, "menubutton");
+    const dropdownIcon = useIcon("dropdown", propIcon);
+    let icon = propIcon;
+    if (!disableDropdownIcon) {
+      icon = (
+        <IconRotator {...iconRotatorProps} rotated={visible}>
+          {dropdownIcon}
+        </IconRotator>
+      );
+    }
+
+    return (
+      <Button
+        {...remaining}
+        id={id}
+        ref={ref}
+        floating={floating}
+        theme={theme}
+        themeType={themeType}
+        buttonType={buttonType}
+        onClick={(event) => {
+          onClick?.(event);
+          if (menuitem || menubar) {
+            // do not allow the default menu close behavior from
+            // triggering for parent menus
+            event.stopPropagation();
+          }
+
+          // focusIndex.current = 0;
+          setVisible((prevVisible) => !prevVisible);
+        }}
+        onKeyDown={(event) => {
+          onKeyDown?.(event);
+        }}
+      >
+        {!iconAfter && icon}
+        {children}
+        {iconAfter && icon}
+      </Button>
+    );
+  }
+);
