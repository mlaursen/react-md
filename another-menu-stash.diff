+// import { useAppSize } from "@react-md/core";
+import type { ReactElement, ReactNode, Ref } from "react";
+import { Menu } from "./Menu";
+import {
+  BaseMenuRendererProps,
+  MenuListProps,
+  MenuProps,
+  MenuTransitionProps,
+} from "./types";
+
+/**
+ * @internal
+ * @remarks \@since 5.0.0
+ */
+export type MenuRendererProps = MenuProps &
+  BaseMenuRendererProps &
+  MenuListProps &
+  MenuTransitionProps & {
+    nodeRef: Ref<HTMLDivElement>;
+    children: ReactNode;
+  };
+
+/**
+ * This component conditionally renders either the `Menu` or `MenuSheet`
+ * component based on the current menu configuration.
+ *
+ * @internal
+ * @remarks \@since 5.0.0
+ */
+export function MenuRenderer(props: MenuRendererProps): ReactElement {
+  const {
+    nodeRef,
+    menuProps,
+    menuStyle,
+    menuClassName,
+    sheetProps,
+    sheetStyle,
+    sheetClassName,
+    sheetMenuProps,
+    children,
+    horizontal,
+    horizontal: propHorizontal,
+    renderAsSheet: propRenderAsSheet,
+    sheetHeader: propSheetHeader,
+    sheetFooter: propSheetFooter,
+    sheetPosition: propSheetPosition,
+    sheetVerticalSize: propSheetVerticalSize,
+    onClick,
+    onKeyDown,
+    ...remaining
+  } = props;
+
+  // const { isPhone } = useAppSize();
+  // const {
+  //   horizontal,
+  //   renderAsSheet,
+  //   sheetHeader,
+  //   sheetFooter,
+  //   sheetPosition,
+  //   sheetVerticalSize,
+  // } = useMenuConfiguration({
+  //   horizontal: propHorizontal,
+  //   renderAsSheet: propRenderAsSheet,
+  //   sheetHeader: propSheetHeader,
+  //   sheetFooter: propSheetFooter,
+  //   sheetPosition: propSheetPosition,
+  //   sheetVerticalSize: propSheetVerticalSize,
+  // });
+  const handlers = {
+    onClick,
+    onKeyDown,
+  };
+
+  // const sheet =
+  //   renderAsSheet === true || (renderAsSheet === "phone" && isPhone);
+  return (
+    <>
+      <Menu
+        {...remaining}
+        {...menuProps}
+        {...handlers}
+        ref={nodeRef}
+        style={menuStyle}
+        className={menuClassName}
+        horizontal={horizontal}
+      >
+        {children}
+      </Menu>
+    </>
+  );
+}
