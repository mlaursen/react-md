{
  "name": "project-root",
  "type": "module",
  "private": true,
  "scripts": {
    "prepare": "husky",
    "turbo-s": "cross-env TURBO_NO_UPDATE_NOTIFIER=1 TURBO_TELEMETRY_DISABLED=1 turbo",
    "format": "pnpm turbo-s format",
    "check-format": "pnpm turbo-s check-format",
    "lint": "pnpm turbo-s lint",
    "lint-fix": "pnpm turbo-s lint-fix",
    "test": "TURBO_UI=true pnpm turbo-s test",
    "test-coverage": "TURBO_UI=true pnpm turbo-s test-coverage",
    "test-run": "pnpm turbo-s test-run",
    "test-run-snapshot": "pnpm turbo-s test-run-snapshot",
    "test-run-coverage": "pnpm turbo-s test-run-coverage --concurrency=1",
    "typecheck": "pnpm turbo-s typecheck",
    "typecheck-watch": "pnpm turbo-s typecheck-watch",
    "build": "pnpm turbo-s build",
    "build-code": "pnpm turbo-s build --filter @react-md/code",
    "build-core": "pnpm turbo-s build --filter @react-md/core",
    "build-docs": "pnpm turbo-s build --filter docs",
    "build-docs-generator": "pnpm turbo-s build --filter docs-generator",
    "build-sassdoc": "pnpm turbo-s build --filter sassdoc-generator",
    "build-packages": "pnpm turbo-s build --filter=docs^...",
    "update-sassdoc": "pnpm --filter docs sassdoc",
    "update-material-icons": "pnpm --filter material-icons update-icons",
    "next-playground-dev": "pnpm --filter next-playground dev",
    "vite-playground-dev": "pnpm --filter vite-playground dev",
    "code-dev": "pnpm --filter code dev",
    "core-dev": "pnpm --filter core dev",
    "docs-dev": "pnpm --filter docs dev",
    "docs-generator-dev": "pnpm --filter docs-generator dev",
    "sassdoc-dev": "pnpm --filter sassdoc-generator dev",
    "clean": "pnpm turbo-s clean && pnpm clean-root",
    "clean-dist": "pnpm turbo-s clean-dist",
    "clean-root": "rm -rf .turbo coverage node_modules",
    "core-export-map": "pnpm --filter core export-map",
    "core-index-file": "pnpm --filter core create-index-file",
    "validate": "pnpm lint && pnpm typecheck",
    "changeset": "changeset",
    "turbo-release": "pnpm turbo-s --filter=react-md --filter=@react-md/codemod --filter=@react-md/material-icons",
    "clean-release-dist": "pnpm turbo-release clean-dist",
    "build-release-packages": "pnpm turbo-release build",
    "build-release": "pnpm core-index-file && pnpm build-release-packages",
    "release": "node scripts/release.ts"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@mlaursen/release-script": "^0.2.0",
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@typescript/native-preview": "beta",
    "cross-env": "^10.1.0",
    "eslint": "^9.39.4",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "turbo": "^2.9.6",
    "typescript": "npm:@typescript/typescript6@^6.0.0"
  },
  "lint-staged": {
    "**/*.{scss,js,jsx,md,yml,json,ts,tsx}": [
      "prettier --write"
    ]
  },
  "engines": {
    "node": "24.15.0",
    "pnpm": "10.33.2"
  },
  "engineStrict": true,
  "packageManager": "pnpm@10.33.2",
  "volta": {
    "node": "24.15.0",
    "pnpm": "10.33.2"
  }
}
