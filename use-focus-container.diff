+import { randomInt } from "@react-md/core";
+import { nanoid } from "nanoid";
+import { loremIpsum } from "./loremIpsum";
+
+export interface Metadata {
+  createdOn: string;
+  createdBy: string;
+  modifiedOn: string;
+  modifiedBy: string;
+}
+
+export interface Folder extends Metadata {
+  name: string;
+  folderId: string;
+  parentFolderId: string | null;
+}
+
+export type FolderRecord = Record<string, Readonly<Folder>>;
+
+interface Options {
+  roots?: number;
+  maxDepth?: number;
+  minPerLevel?: number;
+  maxPerLevel?: number;
+}
+
+const userIds = Array.from({ length: 4 }, () => nanoid());
+const timestamps = [
+  new Date().toISOString(),
+  new Date(2020, 0, 1).toISOString(),
+  new Date(2021, 4, 2, 3, 1, 300).toISOString(),
+  new Date(2021, 8, 5, 28, 100, 300).toISOString(),
+  new Date(Date.now() - 4893020).toISOString(),
+];
+
+function createFolder(parentFolderId: string | null): Folder {
+  const userId = userIds[randomInt({ min: 0, max: userIds.length - 1 })];
+  const timestamp =
+    timestamps[randomInt({ min: 0, max: timestamps.length - 1 })];
+  return {
+    name: loremIpsum({ minWords: 1, maxWords: 3 }),
+    folderId: nanoid(),
+    parentFolderId,
+    createdBy: userId,
+    createdOn: timestamp,
+    modifiedBy: userId,
+    modifiedOn: timestamp,
+  };
+}
+
+interface Options2 {
+  folders: FolderRecord;
+  depth: number;
+  maxDepth: number;
+  minPerLevel: number;
+  maxPerLevel: number;
+  parentFolderId: string | null;
+}
+
+function createFolders(options: Options2): void {
+  const { depth, maxDepth, folders, minPerLevel, maxPerLevel, parentFolderId } =
+    options;
+
+  const count = randomInt({
+    min: minPerLevel,
+    max: maxPerLevel,
+  });
+
+  for (let i = 0; i < count; i += 1) {
+    const folder = createFolder(parentFolderId);
+    folders[folder.folderId] = folder;
+
+    if (depth < maxDepth) {
+      createFolders({
+        folders,
+        depth: depth + 1,
+        maxDepth,
+        minPerLevel,
+        maxPerLevel,
+        parentFolderId: folder.folderId,
+      });
+    }
+  }
+}
+
