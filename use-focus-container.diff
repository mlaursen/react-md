+      ariaHidden.textContent = "aria hidden";
+      ariaHidden.setAttribute("aria-hidden", "true");
+      return ariaHidden;
+    };
+    const createHidden = (): HTMLElement => {
+      const hidden = document.createElement("div");
+      hidden.textContent = "hidden";
