+
+    fireEvent.keyDown(listbox, { key: "O" });
+    expect(document.activeElement).toBe(listbox);
+    expect(listbox).toHaveAttribute("aria-activedescendant", "option-2");
+    expect(option1).not.toHaveClass("active");
