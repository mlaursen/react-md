--- /dev/null
+++ b/src/utils/useFolders.ts
@@ -0,0 +1,39 @@
+import { useEffect, useState } from "react";
+import { Folder, generateFolders } from "./folders";
+import { wait } from "./wait";
+
+interface ReturnValue {
+  data?: Readonly<Record<string, Readonly<Folder>>> | undefined;
+  error?: unknown;
+  loading: boolean;
+}
+
+export function useFolders(delayInMs = 2000): ReturnValue {
+  const [state, setState] = useState<ReturnValue>({ loading: false });
+  useEffect(() => {
+    let cancelled = false;
+    const load = async (): Promise<void> => {
+      setState({ loading: true });
+      const folders = await generateFolders({
+        roots: 4,
+        maxDepth: 1,
+        minPerLevel: 0,
+        maxPerLevel: 10,
+      });
+      // const folders = (await import("src/constants/folders.json")).default;
+      await wait(delayInMs);
+      if (!cancelled) {
+        console.log("total", Object.values(folders).length);
+        setState({ loading: false, data: folders });
+      }
+    };
+
+    load();
+
+    return () => {
+      cancelled = true;
+    };
+  }, [delayInMs]);
+
+  return state;
+}
