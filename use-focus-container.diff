+import { Button } from "@react-md/button";
+import {
+  Box,
+  ElementInteractionProvider,
+  randomInt,
+  SkeletonPlaceholder,
+  TextContainer,
+  Typography,
+} from "@react-md/core";
+import { Divider } from "@react-md/divider";
+import { ListItemChildrenAddonProps } from "@react-md/list";
+import FolderIcon from "@react-md/material-icons/FolderIcon";
+import FolderOpenIcon from "@react-md/material-icons/FolderOpenIcon";
+import {
+  DefaultTreeItemRenderer,
+  GetTreeItemProps,
+  IsTreeItem,
+  ReadonlyTreeData,
+  Tree,
+  TreeData,
+  TreeExpansionMode,
+  TreeItemNode,
+  TreeItemRendererProps,
+  useTree,
+} from "@react-md/tree";
+import { nanoid } from "nanoid";
+import { ReactElement, useCallback, useMemo, useState } from "react";
+import { TempRadio } from "src/components/TempRadio";
+import { folders } from "src/constants/folders";
+import { useFolders } from "src/utils/useFolders";
+
+const data = Object.values(folders).reduce<
+  Record<string, TreeItemNode & ListItemChildrenAddonProps>
+>((result, folder) => {
+  result[folder.itemId] = {
+    ...folder,
+    leftAddon: <FolderIcon />,
+  };
+
+  return result;
+}, {});
+
+function CustomRenderer<T extends TreeItemNode>(
+  props: TreeItemRendererProps<T>
+): ReactElement {
+  const { item } = props;
+  if (item.itemId.startsWith("divider-")) {
+    return <Divider inset />;
+  }
+
+  return <DefaultTreeItemRenderer {...props} />;
+}
+
+function Demo(): ReactElement {
+  const {
+    expandedIds,
+    onItemExpansion,
+    onMultiItemExpansion,
+    selectedIds,
+    onItemSelection,
+    onMultiItemSelection,
+  } = useTree();
+
+  const [expansionMode, setExpansionMode] = useState<TreeExpansionMode>("auto");
+  const [expanderLeft, setExpanderLeft] = useState(false);
+  const [disableTransition, setDisableTransition] = useState(false);
+
+  const { data: folders, loading } = useFolders(4000);
+  const data = useMemo<ReadonlyTreeData>(() => {
+    if (!folders || loading) {
+      return {
+        loading: {
+          itemId: "loading",
+          parentId: null,
+          children: <SkeletonPlaceholder />,
+          disabled: true,
+        },
+      };
+    }
+
+    return Object.values(folders).reduce<TreeData>((result, folder) => {
+      const { folderId, name, parentFolderId } = folder;
+      result[folderId] = {
+        name,
+        itemId: folderId,
+        parentId: parentFolderId,
+      };
+
+      if (randomInt() % 2 === 0) {
+        const itemId = `divider-${nanoid()}`;
+        result[itemId] = {
+          itemId,
+          parentId: parentFolderId,
+        };
+      }
+
+      return result;
+    }, {});
+  }, [folders, loading]);
+
+  return (
+    <TextContainer>
+      <Box>
+        <TempRadio
+          label="Auto Expansion"
+          checked={expansionMode === "auto"}
+          value="auto"
+          onChange={() => setExpansionMode("auto")}
+          name="expansionMode"
+        />
+        <TempRadio
+          label="Manual Expansion"
+          checked={expansionMode === "manual"}
+          value="manual"
+          onChange={() => setExpansionMode("manual")}
+          name="expansionMode"
+        />
+      </Box>
+      <Box>
+        <label>
+          Disable Transitions?
+          <input
+            type="checkbox"
+            name="disableTransition"
+            checked={disableTransition}
+            onChange={(event) =>
+              setDisableTransition(event.currentTarget.checked)
+            }
+          />
+        </label>
+        <label>
+          Expander Left?
+          <input
+            type="checkbox"
+            name="expanderLeft"
+            checked={expanderLeft}
+            onChange={(event) => setExpanderLeft(event.currentTarget.checked)}
+          />
+        </label>
+      </Box>
+      <Typography type="headline-4">Tree</Typography>
+      <ElementInteractionProvider mode={disableTransition ? "none" : undefined}>
+        <Tree
+          aria-label="Tree"
+          data={data}
+          expandedIds={expandedIds}
+          selectedIds={selectedIds}
+          expanderLeft={expanderLeft}
+          expansionMode={expansionMode}
+          onItemExpansion={onItemExpansion}
+          onItemSelection={onItemSelection}
+          onMultiItemExpansion={onMultiItemExpansion}
+          onMultiItemSelection={onMultiItemSelection}
+          disableTransition={disableTransition}
+          getTreeItemProps={useCallback<GetTreeItemProps>(
+            ({ expanded, depth, item }) => ({
+              disabled: depth > 1 || item.disabled,
+              leftAddon: expanded ? <FolderOpenIcon /> : <FolderIcon />,
+            }),
+            []
+          )}
+          renderer={CustomRenderer}
+          isTreeItem={useCallback<IsTreeItem>(
+            (item) => !item.itemId.startsWith("divider-"),
+            []
+          )}
+        />
+      </ElementInteractionProvider>
+    </TextContainer>
+  );
+}
+
+export default function TreePage(): ReactElement {
+  const [key, setKey] = useState(0);
+
+  return (
+    <>
+      <Button onClick={() => setKey(Date.now())}>Reset</Button>
+      <Demo key={key} />
+    </>
+  );
+}
