{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": ["**/.env.*local"],
  "tasks": {
    "docs#build-env": {
      "dependsOn": ["^build"],
      "outputs": [".env.local"]
    },
    "docs#sassdoc": {
      "dependsOn": ["^build"],
      "outputs": ["src/generated/sassdoc/**"]
    },
    "docs#build-typedoc": {
      "dependsOn": ["^build"],
      "outputs": ["public/typedoc/**"]
    },
    "docs#build": {
      "dependsOn": [
        "^build",
        "docs#build-env",
        "docs#sassdoc",
        "docs#build-typedoc"
      ],
      "outputs": [
        "src/generated/**",
        "public/typedoc/**",
        ".next/**",
        "!.next/cache/**"
      ]
    },
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", "types/**"]
    },
    "lint": {},
    "lint-fix": {},
    "format": {},
    "check-format": {},
    "typecheck": {},
    "test": {
      "interactive": true,
      "cache": false
    },
    "test-run": {
      "dependsOn": ["^build"]
    },
    "test-coverage": {
      "interactive": true,
      "cache": false,
      "outputs": ["coverage/**"]
    },
    "test-run-coverage": {
      "dependsOn": ["^build"],
      "outputs": ["coverage/**"]
    },
    "test-run-snapshot": {
      "dependsOn": ["^build"]
    },
    "clean": {
      "cache": false
    },
    "clean-dist": {
      "cache": false
    }
  }
}
